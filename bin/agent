Show the git diff from an agent's working tree inside its Docker container.

Options:
  --stat    Show a diffstat summary instead of the full diff

Examples:
  agent diff api-refactor
  agent diff --latest
  agent diff --latest --stat
EOF
}

print_help_checkpoint() {
  cat <<EOF
Usage: agent checkpoint <create|list|revert> <name>|--latest [...]

Snapshot and revert an agent's working tree using git stash objects stored
as named refs under refs/safe-agentic/checkpoints/.

Subcommands:
  create <name>|--latest [label]   Snapshot current changes (default label: checkpoint-<epoch>)
  list   <name>|--latest           List all checkpoints for the container
  revert <name>|--latest <ref>     Restore a checkpoint (discards current changes)

Options:
  --latest    Target the most recently started container
  -h, --help  Show this help

Examples:
  agent checkpoint create my-task before-refactor
  agent checkpoint list my-task
  agent checkpoint revert my-task before-refactor
  agent checkpoint create --latest
  agent checkpoint list --latest
EOF
}

print_help_todo() {
  cat <<EOF
Usage: agent todo <add|list|check|uncheck> <name>|--latest [...]

Track merge requirements for an agent's working tree. Todos are stored in
/workspace/.safe-agentic/todos.json inside the container.

Subcommands:
  add     <name>|--latest <text>    Add a new todo item
  list    <name>|--latest           List all todos with status
  check   <name>|--latest <index>   Mark todo at 1-based index as done
  uncheck <name>|--latest <index>   Mark todo at 1-based index as not done

Options:
  --latest    Target the most recently started container
  -h, --help  Show this help

Examples:
  agent todo add my-task "Add unit tests for auth module"
  agent todo list my-task
  agent todo check my-task 1
  agent todo uncheck --latest 2
  agent todo list --latest
EOF
}

print_help_review() {
  cat <<EOF
Usage: agent review <name>|--latest [--base BRANCH]

Run an AI code review (codex) or git diff of changes in a running agent's
workspace.  If codex is available in the container it is used; otherwise
falls back to plain git diff.

Options:
  --base BRANCH   Compare against BRANCH (codex review --base / git diff)
                  Without --base, reviews all uncommitted changes.
  --latest        Use the most recently started container.
  -h, --help      Show this help.

Examples:
  agent review my-task
  agent review --latest --base main
  agent review my-task --base origin/main
EOF
}

