#!/usr/bin/env bash
set -euo pipefail

REPO_DIR="$(cd "$(dirname "$(realpath "$0")")/.." && pwd)"
IMAGE_NAME="safe-agentic"
IMAGE_TAG="latest"
CONTAINER_PREFIX="agent"
VM_NAME="safe-agentic"

RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
NC='\033[0m'

info()  { echo -e "${CYAN}[agent]${NC} $*"; }
ok()    { echo -e "${GREEN}[agent]${NC} $*"; }
warn()  { echo -e "${YELLOW}[agent]${NC} $*"; }
err()   { echo -e "${RED}[agent]${NC} $*" >&2; }
die()   { err "$@"; exit 1; }

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "'$1' is required but not installed."
}

require_vm() {
  orb list 2>/dev/null | grep -q "$VM_NAME" || die "VM '$VM_NAME' not found. Run 'agent setup' first."
}

vm_exec() {
  orb run -m "$VM_NAME" "$@"
}

vm_copy_from_host() {
  local source_path="$1"
  local destination_path="$2"

  [ -f "$source_path" ] || die "Local file not found: $source_path"
  # shellcheck disable=SC2016
  orb run -m "$VM_NAME" env DEST="$destination_path" bash -c 'cat > "$DEST"' < "$source_path"
}

source "$REPO_DIR/bin/agent-lib.sh"
# shellcheck disable=SC1091
source "$REPO_DIR/bin/docker-runtime.sh"

load_user_defaults
apply_default_identity

DEFAULT_CPUS="${SAFE_AGENTIC_DEFAULT_CPUS:-4}"
DEFAULT_MEMORY="${SAFE_AGENTIC_DEFAULT_MEMORY:-8g}"
DEFAULT_PIDS_LIMIT="${SAFE_AGENTIC_DEFAULT_PIDS_LIMIT:-512}"
DEFAULT_NETWORK="${SAFE_AGENTIC_DEFAULT_NETWORK:-}"
DEFAULT_REUSE_AUTH=false
DEFAULT_REUSE_GH_AUTH=false
DEFAULT_SSH=false
DEFAULT_DOCKER=false
DEFAULT_DOCKER_SOCKET=false

bool_is_true "${SAFE_AGENTIC_DEFAULT_REUSE_AUTH:-}" && DEFAULT_REUSE_AUTH=true
bool_is_true "${SAFE_AGENTIC_DEFAULT_REUSE_GH_AUTH:-}" && DEFAULT_REUSE_GH_AUTH=true
bool_is_true "${SAFE_AGENTIC_DEFAULT_SSH:-}" && DEFAULT_SSH=true
bool_is_true "${SAFE_AGENTIC_DEFAULT_DOCKER:-}" && DEFAULT_DOCKER=true
bool_is_true "${SAFE_AGENTIC_DEFAULT_DOCKER_SOCKET:-}" && DEFAULT_DOCKER_SOCKET=true

die_with_help() {
  local topic="$1"
  shift

  die "$*. Run 'agent help${topic:+ $topic}' for usage."
}

require_option_value() {
  local topic="$1"
  local flag="$2"
  local value="${3:-}"

  [ -n "$value" ] || die_with_help "$topic" "Missing value for $flag."
}

print_help_general() {
  cat <<EOF
${CYAN}safe-agentic${NC} — isolated AI agent environment

${GREEN}Setup:${NC}
  agent setup
  agent diagnose

${GREEN}Run:${NC}
  agent spawn <claude|codex> [options]
  agent shell [options]
  agent-claude [spawn-options] <repo-url> [repo-url...]
  agent-codex [spawn-options] <repo-url> [repo-url...]

${GREEN}Manage:${NC}
  agent list [--json]
  agent summary <name>|--latest
  agent config <show|set|get|reset>
  agent tui
  agent attach <name>|--latest
  agent cp <name>|--latest <container-path> <host-path>
  agent peek <name>|--latest [--lines N]
  agent diff <name>|--latest [--stat]
  agent checkpoint <create|list|revert> <name>|--latest [...]
  agent todo <add|list|check|uncheck> <name>|--latest [...]
  agent stop <name>|--latest|--all
  agent cleanup [--auth]

${GREEN}Observe:${NC}
  agent review <name>|--latest [--base BRANCH]
  agent cost <name>|--latest

${GREEN}Analytics:${NC}
  agent audit [--lines N]

${GREEN}Orchestrate:${NC}
  agent fleet <manifest.yaml> [--dry-run]
  agent pipeline <pipeline.yaml> [--dry-run]

${GREEN}Workflow:${NC}
  agent pr <name>|--latest [--title TITLE] [--base BRANCH]

${GREEN}AWS:${NC}
  agent aws-refresh <name>|--latest [profile]

${GREEN}Maintain:${NC}
  agent update [--quick|--full]
  agent vm <ssh|stop|start>

${GREEN}Help:${NC}
  agent help [spawn|shell|attach|peek|diff|checkpoint|todo|cp|review|cost|audit|fleet|pipeline|pr|stop|cleanup|update|vm|diagnose|config|summary]
  agent help <keyword>  (search all help text)

${GREEN}Examples:${NC}
  agent-claude git@github.com:myorg/myrepo.git
  agent spawn codex --reuse-auth --identity 'You <you@example.com>' --repo https://github.com/myorg/api.git
  agent shell --dry-run --repo https://github.com/myorg/myrepo.git
  agent fleet agents.yaml --dry-run
  agent pipeline my-workflow.yaml --dry-run
EOF
}

print_help_spawn() {
  cat <<EOF
Usage: agent spawn <claude|codex> [options]

Options:
  --repo URL
  --name NAME
  --ssh
  --reuse-auth
  --reuse-gh-auth
  --docker
  --docker-socket
  --network NAME
  --memory SIZE
  --cpus N
  --pids-limit N
  --prompt 'TASK'
  --aws PROFILE
  --identity 'Name <email@example.com>'
  --auto-trust
  --background
  --dry-run
  -h, --help

Notes:
  - --prompt sends an initial task to the agent (claude -p / codex positional arg)
  - --auto-trust skips the "trust this project?" prompt (useful for fleet/pipeline)
  - --background runs headless (no tmux, not attachable, output via docker logs)
  - --aws injects credentials from ~/.aws/credentials for the given profile
  - Default network: managed bridge with private/local egress blocked; TCP 22/80/443 only
  - Defaults file: ${DEFAULTS_FILE}
  - SSH repos require --ssh; aliases auto-enable it
  - --docker starts an internal Docker daemon sidecar
  - --docker-socket mounts the VM Docker socket directly (dangerous)
EOF
}

