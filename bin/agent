#!/usr/bin/env bash
# safe-agentic: CLI for managing isolated AI agent containers inside an OrbStack VM.
# Runs on macOS host. Manages the "safe-agentic" OrbStack VM and Docker containers within it.
set -euo pipefail

# ---------------------------------------------------------------------------
# Constants
# ---------------------------------------------------------------------------
REPO_DIR="$(cd "$(dirname "$(realpath "$0")")/.." && pwd)"
IMAGE_NAME="safe-agentic"
IMAGE_TAG="latest"
CONTAINER_PREFIX="agent"
VM_NAME="safe-agentic"

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
NC='\033[0m'

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------
info()  { echo -e "${CYAN}[agent]${NC} $*"; }
ok()    { echo -e "${GREEN}[agent]${NC} $*"; }
warn()  { echo -e "${YELLOW}[agent]${NC} $*"; }
err()   { echo -e "${RED}[agent]${NC} $*" >&2; }
die()   { err "$@"; exit 1; }

require_cmd() {
  command -v "$1" &>/dev/null || die "'$1' is required but not installed."
}

require_vm() {
  orb list 2>/dev/null | grep -q "$VM_NAME" || die "VM '$VM_NAME' not found. Run 'agent setup' first."
}

vm_exec() {
  orb run -m "$VM_NAME" "$@"
}

# ---------------------------------------------------------------------------
# Commands
# ---------------------------------------------------------------------------

cmd_setup() {
  info "Setting up safe-agentic environment..."

  require_cmd orb

  # Create VM if it doesn't exist
  if orb list 2>/dev/null | grep -q "$VM_NAME"; then
    info "VM '$VM_NAME' already exists."
  else
    info "Creating OrbStack VM '$VM_NAME' (Ubuntu)..."
    orb create ubuntu "$VM_NAME"
    ok "VM created."
  fi

  # Ensure VM is running
  orb start "$VM_NAME" 2>/dev/null || true

  # Push setup script and run it
  info "Bootstrapping VM (installing Docker)..."
  orb push -m "$VM_NAME" "$REPO_DIR/vm/setup.sh" /tmp/setup.sh
  vm_exec bash /tmp/setup.sh

  # Build Docker image inside VM
  cmd_update

  ok "Setup complete. Run 'agent spawn claude --ssh --repo <url>' to start."
}

cmd_spawn() {
  local agent_type=""
  local -a repos=()
  local name=""
  local enable_ssh=false
  local reuse_auth=false
  local -a extra_args=()
  local parsing_extra=false

  while [ $# -gt 0 ]; do
    if $parsing_extra; then
      extra_args+=("$1"); shift; continue
    fi
    case "$1" in
      claude|codex)
        agent_type="$1"; shift ;;
      --repo)
        shift; repos+=("$1"); shift ;;
      --name)
        shift; name="$1"; shift ;;
      --ssh)
        enable_ssh=true; shift ;;
      --reuse-auth)
        reuse_auth=true; shift ;;
      --)
        parsing_extra=true; shift ;;
      *)
        die "Unknown argument: $1. Usage: agent spawn <claude|codex> [--repo URL...] [--name NAME] [--ssh] [--reuse-auth] [-- docker flags]" ;;
    esac
  done

  [ -z "$agent_type" ] && die "Agent type required. Usage: agent spawn <claude|codex> [--repo URL...] [--ssh]"

  require_cmd orb
  require_vm

  # Generate container name
  local timestamp
  timestamp=$(date +%s)
  local container_name="${CONTAINER_PREFIX}-${agent_type}-${name:-$timestamp}"

  # Join repos with commas
  local repos_joined=""
  if [ ${#repos[@]} -gt 0 ]; then
    repos_joined=$(IFS=','; echo "${repos[*]}")
  fi

  info "Spawning $agent_type agent: $container_name"
  [ -n "$repos_joined" ] && info "Repos: $repos_joined"

  # Build docker run command as an array (prevents shell-splitting injection)
  local -a docker_cmd=(docker run -it --rm)
  docker_cmd+=(--name "$container_name")
  docker_cmd+=(--hostname "$container_name")
  docker_cmd+=(-e "AGENT_TYPE=$agent_type")

  if [ -n "$repos_joined" ]; then
    docker_cmd+=(-e "REPOS=$repos_joined")
  fi

  # --- Security defaults ---

  # Drop all capabilities, add back only SETUID/SETGID (for apt if needed)
  docker_cmd+=(--cap-drop=ALL --cap-add=SETUID --cap-add=SETGID)
  # Read-only root filesystem
  docker_cmd+=(--read-only)
  # Writable tmpfs for scratch dirs
  docker_cmd+=(--tmpfs /tmp:rw,noexec,nosuid,size=512m)
  docker_cmd+=(--tmpfs /var/tmp:rw,noexec,nosuid,size=256m)
  docker_cmd+=(--tmpfs /run:rw,noexec,nosuid,size=16m)
  # Writable workspace for cloned repos
  docker_cmd+=(-v "${container_name}-workspace:/workspace")
  # Writable home areas not covered by cache mounts
  docker_cmd+=(--tmpfs "/home/agent/.config:rw,noexec,nosuid,uid=1000,gid=1000,size=32m")
  docker_cmd+=(--tmpfs "/home/agent/.ssh:rw,noexec,nosuid,uid=1000,gid=1000,size=1m")
  docker_cmd+=(--tmpfs "/home/agent/.gitconfig:rw,noexec,nosuid,uid=1000,gid=1000,size=1m")
  docker_cmd+=(--tmpfs "/home/agent/.local:rw,noexec,nosuid,uid=1000,gid=1000,size=64m")

  # --- SSH agent: opt-in only ---
  if $enable_ssh; then
    local vm_ssh_sock
    vm_ssh_sock=$(vm_exec bash -c 'echo $SSH_AUTH_SOCK' 2>/dev/null || echo "")
    if [ -n "$vm_ssh_sock" ]; then
      docker_cmd+=(-v "$vm_ssh_sock:/run/ssh-agent.sock:ro")
      docker_cmd+=(-e "SSH_AUTH_SOCK=/run/ssh-agent.sock")
      info "SSH agent forwarding: enabled"
    else
      warn "No SSH_AUTH_SOCK in VM. Git SSH operations may not work."
    fi
  else
    if [ -n "$repos_joined" ] && echo "$repos_joined" | grep -q "git@"; then
      warn "SSH repos detected but --ssh not passed. Clone will fail without SSH agent."
      warn "Re-run with --ssh to enable SSH agent forwarding."
    fi
  fi

  # --- Auth volumes ---
  if $reuse_auth; then
    # Shared auth volume — persists across sessions (opt-in)
    case "$agent_type" in
      claude) docker_cmd+=(-v "agent-claude-auth:/home/agent/.claude") ;;
      codex)  docker_cmd+=(-v "agent-codex-auth:/home/agent/.codex") ;;
    esac
    info "Auth: reusing shared session"
  else
    # Per-session auth volume — isolated, discarded on cleanup (default)
    case "$agent_type" in
      claude) docker_cmd+=(-v "${container_name}-claude-auth:/home/agent/.claude") ;;
      codex)  docker_cmd+=(-v "${container_name}-codex-auth:/home/agent/.codex") ;;
    esac
    info "Auth: per-session (use --reuse-auth to persist)"
  fi

  # Per-agent cache volumes (isolated — prevents cross-agent cache poisoning)
  docker_cmd+=(-v "${container_name}-npm-cache:/home/agent/.npm")
  docker_cmd+=(-v "${container_name}-pip-cache:/home/agent/.cache/pip")
  docker_cmd+=(-v "${container_name}-go-cache:/home/agent/go")
  docker_cmd+=(-v "${container_name}-terraform-cache:/home/agent/.terraform.d/plugin-cache")

  # Extra docker run flags (e.g., --network agent-isolated) go BEFORE the image name
  if [ ${#extra_args[@]} -gt 0 ]; then
    docker_cmd+=("${extra_args[@]}")
  fi

  docker_cmd+=("$IMAGE_NAME:$IMAGE_TAG")

  # Launch container inside VM
  orb run -m "$VM_NAME" "${docker_cmd[@]}"
}

cmd_shell() {
  local -a repos=()
  local enable_ssh=false
  local -a extra_args=()
  local parsing_extra=false

  while [ $# -gt 0 ]; do
    if $parsing_extra; then
      extra_args+=("$1"); shift; continue
    fi
    case "$1" in
      --repo) shift; repos+=("$1"); shift ;;
      --ssh) enable_ssh=true; shift ;;
      --) parsing_extra=true; shift ;;
      *) die "Unknown argument: $1. Usage: agent shell [--repo URL...] [--ssh] [-- docker flags]" ;;
    esac
  done

  require_cmd orb
  require_vm

  local timestamp
  timestamp=$(date +%s)
  local container_name="${CONTAINER_PREFIX}-shell-${timestamp}"
  local repos_joined=""
  if [ ${#repos[@]} -gt 0 ]; then
    repos_joined=$(IFS=','; echo "${repos[*]}")
  fi

  info "Starting interactive shell: $container_name"

  # Build docker run command as array
  local -a docker_cmd=(docker run -it --rm)
  docker_cmd+=(--name "$container_name")
  docker_cmd+=(--hostname "$container_name")

  if [ -n "$repos_joined" ]; then
    docker_cmd+=(-e "REPOS=$repos_joined")
  fi

  # Security defaults
  docker_cmd+=(--cap-drop=ALL --cap-add=SETUID --cap-add=SETGID)
  docker_cmd+=(--read-only)
  docker_cmd+=(--tmpfs /tmp:rw,noexec,nosuid,size=512m)
  docker_cmd+=(--tmpfs /var/tmp:rw,noexec,nosuid,size=256m)
  docker_cmd+=(--tmpfs /run:rw,noexec,nosuid,size=16m)
  docker_cmd+=(-v "${container_name}-workspace:/workspace")
  docker_cmd+=(--tmpfs "/home/agent/.config:rw,noexec,nosuid,uid=1000,gid=1000,size=32m")
  docker_cmd+=(--tmpfs "/home/agent/.ssh:rw,noexec,nosuid,uid=1000,gid=1000,size=1m")
  docker_cmd+=(--tmpfs "/home/agent/.gitconfig:rw,noexec,nosuid,uid=1000,gid=1000,size=1m")
  docker_cmd+=(--tmpfs "/home/agent/.local:rw,noexec,nosuid,uid=1000,gid=1000,size=64m")

  # SSH agent: opt-in only
  if $enable_ssh; then
    local vm_ssh_sock
    vm_ssh_sock=$(vm_exec bash -c 'echo $SSH_AUTH_SOCK' 2>/dev/null || echo "")
    if [ -n "$vm_ssh_sock" ]; then
      docker_cmd+=(-v "$vm_ssh_sock:/run/ssh-agent.sock:ro")
      docker_cmd+=(-e "SSH_AUTH_SOCK=/run/ssh-agent.sock")
    fi
  fi

  # No auth volumes for plain shell — no agent credentials exposed
  docker_cmd+=(-v "${container_name}-npm-cache:/home/agent/.npm")
  docker_cmd+=(-v "${container_name}-pip-cache:/home/agent/.cache/pip")
  docker_cmd+=(-v "${container_name}-go-cache:/home/agent/go")
  docker_cmd+=(-v "${container_name}-terraform-cache:/home/agent/.terraform.d/plugin-cache")

  # Extra docker run flags
  if [ ${#extra_args[@]} -gt 0 ]; then
    docker_cmd+=("${extra_args[@]}")
  fi

  docker_cmd+=("$IMAGE_NAME:$IMAGE_TAG")

  orb run -m "$VM_NAME" "${docker_cmd[@]}"
}

cmd_list() {
  require_vm
  vm_exec docker ps \
    --filter "name=^${CONTAINER_PREFIX}-" \
    --format "table {{.Names}}\t{{.Status}}\t{{.CreatedAt}}\t{{.Image}}"
}

cmd_attach() {
  local name="${1:-}"
  [ -z "$name" ] && die "Usage: agent attach <name>"
  require_vm

  # Prepend prefix if not already present
  if [[ ! "$name" == ${CONTAINER_PREFIX}-* ]]; then
    name="${CONTAINER_PREFIX}-${name}"
  fi

  info "Attaching to $name..."
  orb run -m "$VM_NAME" docker exec -it "$name" bash
}

cmd_stop() {
  require_vm

  if [ "${1:-}" = "--all" ]; then
    info "Stopping all agent containers..."
    local ids
    ids=$(vm_exec docker ps -q --filter "name=^${CONTAINER_PREFIX}-" 2>/dev/null || echo "")
    if [ -n "$ids" ]; then
      vm_exec docker stop $ids
      ok "All agent containers stopped."
    else
      info "No running agent containers."
    fi
  elif [ -n "${1:-}" ]; then
    local name="$1"
    if [[ ! "$name" == ${CONTAINER_PREFIX}-* ]]; then
      name="${CONTAINER_PREFIX}-${name}"
    fi
    info "Stopping $name..."
    vm_exec docker stop "$name"
    ok "$name stopped."
  else
    die "Usage: agent stop <name|--all>"
  fi
}

cmd_cleanup() {
  require_vm
  info "Cleaning up agent containers..."

  # Stop running containers
  local running
  running=$(vm_exec docker ps -q --filter "name=^${CONTAINER_PREFIX}-" 2>/dev/null || echo "")
  if [ -n "$running" ]; then
    vm_exec docker stop $running
  fi

  # Remove stopped containers
  local stopped
  stopped=$(vm_exec docker ps -aq --filter "name=^${CONTAINER_PREFIX}-" 2>/dev/null || echo "")
  if [ -n "$stopped" ]; then
    vm_exec docker rm $stopped
  fi

  # Remove per-agent volumes (caches, auth, workspace)
  local orphan_vols
  orphan_vols=$(vm_exec docker volume ls -q --filter "name=^${CONTAINER_PREFIX}-" 2>/dev/null \
    | grep -E '-(npm|pip|go|terraform)-cache$|-(claude|codex)-auth$|-workspace$' || echo "")
  if [ -n "$orphan_vols" ]; then
    vm_exec docker volume rm $orphan_vols 2>/dev/null || true
  fi

  # Prune images
  vm_exec docker image prune -f --filter "label=app=safe-agentic" 2>/dev/null || true

  ok "Cleanup complete."
}

cmd_update() {
  local quick=false
  local full=false

  while [ $# -gt 0 ]; do
    case "$1" in
      --quick) quick=true; shift ;;
      --full)  full=true; shift ;;
      *) die "Usage: agent update [--quick|--full]" ;;
    esac
  done

  require_cmd orb
  require_cmd git
  require_vm

  info "Pushing build context to VM (tracked files only)..."
  # List only tracked/staged files (-c), NOT untracked (-o).
  # Filter to files that still exist on disk (handles deleted-but-tracked).
  local tarball
  tarball=$(mktemp /tmp/safe-agentic-ctx-XXXXXX.tar.gz)
  git -C "$REPO_DIR" ls-files -c -z \
    | ( cd "$REPO_DIR" && xargs -0 -I{} sh -c 'test -e "$1" && printf "%s\0" "$1"' _ {} ) \
    | tar -C "$REPO_DIR" --null -T - -czf "$tarball"
  orb push -m "$VM_NAME" "$tarball" /tmp/safe-agentic-ctx.tar.gz
  vm_exec bash -c "rm -rf /tmp/safe-agentic && mkdir -p /tmp/safe-agentic && tar -xzf /tmp/safe-agentic-ctx.tar.gz -C /tmp/safe-agentic"
  rm -f "$tarball"

  local -a build_args=()
  if $quick; then
    info "Quick update: rebuilding AI CLI layer only..."
    build_args+=(--build-arg "CLI_CACHE_BUST=$(date +%s)")
  elif $full; then
    info "Full rebuild: no cache..."
    build_args+=(--no-cache)
  else
    info "Building Docker image..."
  fi

  vm_exec docker build "${build_args[@]}" -t "$IMAGE_NAME:$IMAGE_TAG" /tmp/safe-agentic/

  ok "Image $IMAGE_NAME:$IMAGE_TAG built successfully."
}

cmd_vm() {
  local subcmd="${1:-}"
  shift 2>/dev/null || true

  case "$subcmd" in
    ssh)
      orb ssh "$VM_NAME" ;;
    stop)
      info "Stopping VM..."
      orb stop "$VM_NAME"
      ok "VM stopped." ;;
    start)
      info "Starting VM..."
      orb start "$VM_NAME"
      # Re-apply hardening after start (OrbStack may restore mounts)
      info "Re-applying VM hardening..."
      orb push -m "$VM_NAME" "$REPO_DIR/vm/setup.sh" /tmp/setup.sh
      vm_exec bash /tmp/setup.sh
      ok "VM started and hardened." ;;
    *)
      die "Usage: agent vm <ssh|stop|start>" ;;
  esac
}

cmd_help() {
  cat <<EOF
${CYAN}safe-agentic${NC} — Isolated AI agent environment (safe by default)

${GREEN}Setup:${NC}
  agent setup                  Create OrbStack VM, install Docker, build image

${GREEN}Agent management:${NC}
  agent spawn <claude|codex> [options] [-- docker flags]
    --repo URL                 Repo(s) to clone (repeatable)
    --name NAME                Container name suffix
    --ssh                      Enable SSH agent forwarding (off by default)
    --reuse-auth               Reuse shared auth volume (per-session by default)
  agent shell [--repo URL...] [--ssh]
                               Interactive shell (no agent, no auth volumes)
  agent list                   List running agent containers
  agent attach <name>          Second shell into running agent
  agent stop <name|--all>      Stop container(s)
  agent cleanup                Stop all + remove containers + volumes

${GREEN}Maintenance:${NC}
  agent update [--quick|--full]  Rebuild Docker image (--quick: AI CLIs only)

${GREEN}VM management:${NC}
  agent vm ssh                 SSH into the OrbStack VM
  agent vm stop                Stop the VM
  agent vm start               Start the VM (re-applies hardening)

${GREEN}Quick aliases:${NC}
  agent-claude <repo-url>      agent spawn claude --ssh --repo <url>
  agent-codex <repo-url>       agent spawn codex --ssh --repo <url>

${GREEN}Security defaults:${NC}
  - SSH agent forwarding OFF unless --ssh
  - Per-session auth (login each time) unless --reuse-auth
  - Read-only rootfs, dropped capabilities, tmpfs scratch dirs
  - Per-agent cache volumes (no cross-agent contamination)

${GREEN}Auth:${NC}
  On first spawn, Claude/Codex will show an OAuth URL.
  Open it in your macOS browser to authenticate.
  Use --reuse-auth to persist login across sessions.

${GREEN}Examples:${NC}
  agent setup
  agent spawn claude --ssh --repo git@github.com:myorg/myrepo.git
  agent spawn claude --ssh --reuse-auth --repo git@github.com:myorg/myrepo.git
  agent spawn codex --ssh --repo git@github.com:myorg/api.git --name api-fix
  agent spawn claude --repo git@github.com:myorg/a.git -- --network agent-isolated
  agent list
  agent attach claude-api-fix
  agent stop --all
EOF
}

# ---------------------------------------------------------------------------
# Main dispatch
# ---------------------------------------------------------------------------
cmd="${1:-help}"
shift 2>/dev/null || true

case "$cmd" in
  setup)   cmd_setup "$@" ;;
  spawn)   cmd_spawn "$@" ;;
  shell)   cmd_shell "$@" ;;
  list)    cmd_list "$@" ;;
  attach)  cmd_attach "$@" ;;
  stop)    cmd_stop "$@" ;;
  cleanup) cmd_cleanup "$@" ;;
  update)  cmd_update "$@" ;;
  vm)      cmd_vm "$@" ;;
  help|-h|--help) cmd_help ;;
  *)       die "Unknown command: $cmd. Run 'agent help' for usage." ;;
esac
