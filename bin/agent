#!/usr/bin/env bash
set -euo pipefail

REPO_DIR="$(cd "$(dirname "$(realpath "$0")")/.." && pwd)"
IMAGE_NAME="safe-agentic"
IMAGE_TAG="latest"
CONTAINER_PREFIX="agent"
VM_NAME="safe-agentic"

RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
NC='\033[0m'

info()  { echo -e "${CYAN}[agent]${NC} $*"; }
ok()    { echo -e "${GREEN}[agent]${NC} $*"; }
warn()  { echo -e "${YELLOW}[agent]${NC} $*"; }
err()   { echo -e "${RED}[agent]${NC} $*" >&2; }
die()   { err "$@"; exit 1; }

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "'$1' is required but not installed."
}

require_vm() {
  orb list 2>/dev/null | grep -q "$VM_NAME" || die "VM '$VM_NAME' not found. Run 'agent setup' first."
}

vm_exec() {
  orb run -m "$VM_NAME" "$@"
}

vm_copy_from_host() {
  local source_path="$1"
  local destination_path="$2"

  [ -f "$source_path" ] || die "Local file not found: $source_path"
  orb run -m "$VM_NAME" env DEST="$destination_path" bash -c 'cat > "$DEST"' < "$source_path"
}

source "$REPO_DIR/bin/agent-lib.sh"

load_user_defaults
apply_default_identity

DEFAULT_CPUS="${SAFE_AGENTIC_DEFAULT_CPUS:-4}"
DEFAULT_MEMORY="${SAFE_AGENTIC_DEFAULT_MEMORY:-8g}"
DEFAULT_PIDS_LIMIT="${SAFE_AGENTIC_DEFAULT_PIDS_LIMIT:-512}"
DEFAULT_NETWORK="${SAFE_AGENTIC_DEFAULT_NETWORK:-}"
DEFAULT_REUSE_AUTH=false
DEFAULT_SSH=false

bool_is_true "${SAFE_AGENTIC_DEFAULT_REUSE_AUTH:-}" && DEFAULT_REUSE_AUTH=true
bool_is_true "${SAFE_AGENTIC_DEFAULT_SSH:-}" && DEFAULT_SSH=true

die_with_help() {
  local topic="$1"
  shift

  die "$*. Run 'agent help${topic:+ $topic}' for usage."
}

require_option_value() {
  local topic="$1"
  local flag="$2"
  local value="${3:-}"

  [ -n "$value" ] || die_with_help "$topic" "Missing value for $flag."
}

print_help_general() {
  cat <<EOF
${CYAN}safe-agentic${NC} — isolated AI agent environment

${GREEN}Setup:${NC}
  agent setup
  agent diagnose

${GREEN}Run:${NC}
  agent spawn <claude|codex> [options]
  agent shell [options]
  agent-claude [spawn-options] <repo-url> [repo-url...]
  agent-codex [spawn-options] <repo-url> [repo-url...]

${GREEN}Manage:${NC}
  agent list
  agent attach <name>|--latest
  agent stop <name>|--latest|--all
  agent cleanup [--auth]

${GREEN}Maintain:${NC}
  agent update [--quick|--full]
  agent vm <ssh|stop|start>

${GREEN}Help:${NC}
  agent help [spawn|shell|attach|stop|cleanup|update|vm|diagnose]

${GREEN}Examples:${NC}
  agent-claude git@github.com:myorg/myrepo.git
  agent spawn codex --reuse-auth --identity 'You <you@example.com>' --repo https://github.com/myorg/api.git
  agent shell --dry-run --repo https://github.com/myorg/myrepo.git
EOF
}

print_help_spawn() {
  cat <<EOF
Usage: agent spawn <claude|codex> [options]

Options:
  --repo URL
  --name NAME
  --ssh
  --reuse-auth
  --network NAME
  --memory SIZE
  --cpus N
  --pids-limit N
  --identity 'Name <email@example.com>'
  --dry-run
  -h, --help

Notes:
  - Default network: managed bridge with private/local egress blocked; TCP 22/80/443 only
  - Defaults file: ${DEFAULTS_FILE}
  - SSH repos require --ssh; aliases auto-enable it
EOF
}

print_help_shell() {
  cat <<EOF
Usage: agent shell [options]

Options:
  --repo URL
  --ssh
  --network NAME
  --memory SIZE
  --cpus N
  --pids-limit N
  --identity 'Name <email@example.com>'
  --dry-run
  -h, --help
EOF
}

print_help_attach() {
  cat <<EOF
Usage: agent attach <name>|--latest

Examples:
  agent attach api-refactor
  agent attach agent-claude-api-refactor
  agent attach --latest
EOF
}

print_help_stop() {
  cat <<EOF
Usage: agent stop <name>|--latest|--all
EOF
}

print_help_cleanup() {
  cat <<EOF
Usage: agent cleanup [--auth]

By default:
  - stops containers
  - removes managed networks
  - prunes safe-agentic image layers
  - keeps shared auth volumes

Add --auth to remove shared auth volumes too.
EOF
}

print_help_update() {
  cat <<EOF
Usage: agent update [--quick|--full]

Flags:
  --quick   Rebuild AI CLI layer only
  --full    Rebuild from scratch
EOF
}

print_help_vm() {
  cat <<EOF
Usage: agent vm <ssh|stop|start>
EOF
}

print_help_diagnose() {
  cat <<EOF
Usage: agent diagnose

Checks:
  - orb installed and reachable
  - VM exists
  - Docker works in VM
  - hardening still applied
  - image present
  - VM SSH agent socket visible
  - defaults file detected
EOF
}

cmd_setup() {
  require_cmd orb

  info "[1/3] Ensuring VM exists..."
  if orb list 2>/dev/null | grep -q "$VM_NAME"; then
    info "VM '$VM_NAME' already exists."
  else
    info "Creating OrbStack VM '$VM_NAME' (Ubuntu)..."
    orb create ubuntu "$VM_NAME"
    ok "VM created."
  fi

  orb start "$VM_NAME" 2>/dev/null || true

  info "[2/3] Bootstrapping VM runtime..."
  reapply_vm_runtime_hardening

  info "[3/3] Building safe-agentic image..."
  cmd_update

  ok "Setup complete. Try: agent-claude https://github.com/myorg/myrepo.git"
}

show_dry_run() {
  local managed_network="$1"
  local network_name="$2"

  info "Dry run only. No container started."
  if $managed_network; then
    local bridge_name
    bridge_name=$(bridge_name_for_network "$network_name")
    info "Would create network: $(render_command orb run -m "$VM_NAME" docker network create --driver bridge --opt "com.docker.network.bridge.name=$bridge_name" --opt com.docker.network.bridge.enable_icc=false --label "app=$IMAGE_NAME" --label "safe-agentic.type=container-network" "$network_name")"
  else
    info "Would use network: $network_name"
  fi
  info "Would run: $(render_command orb run -m "$VM_NAME" "${docker_cmd[@]}")"
}

cmd_spawn() {
  local topic="spawn"
  local agent_type=""
  local -a repos=()
  local name=""
  local enable_ssh="$DEFAULT_SSH"
  local reuse_auth="$DEFAULT_REUSE_AUTH"
  local custom_network_name="$DEFAULT_NETWORK"
  local memory="$DEFAULT_MEMORY"
  local cpus="$DEFAULT_CPUS"
  local pids_limit="$DEFAULT_PIDS_LIMIT"
  local managed_network=true
  local network_name=""
  local dry_run=false
  local timestamp container_name repos_joined="" repo_display network_mode_label auth_volume_name

  [ -n "$custom_network_name" ] && managed_network=false

  while [ $# -gt 0 ]; do
    case "$1" in
      claude|codex)
        [ -z "$agent_type" ] || die_with_help "$topic" "Agent type already set to '$agent_type'."
        agent_type="$1"
        shift
        ;;
      --repo)
        require_option_value "$topic" "--repo" "${2:-}"
        repos+=("$2")
        shift 2
        ;;
      --name)
        require_option_value "$topic" "--name" "${2:-}"
        name="$2"
        shift 2
        ;;
      --ssh)
        enable_ssh=true
        shift
        ;;
      --reuse-auth)
        reuse_auth=true
        shift
        ;;
      --network)
        require_option_value "$topic" "--network" "${2:-}"
        custom_network_name="$2"
        managed_network=false
        shift 2
        ;;
      --memory)
        require_option_value "$topic" "--memory" "${2:-}"
        memory="$2"
        shift 2
        ;;
      --cpus)
        require_option_value "$topic" "--cpus" "${2:-}"
        cpus="$2"
        shift 2
        ;;
      --pids-limit)
        require_option_value "$topic" "--pids-limit" "${2:-}"
        pids_limit="$2"
        shift 2
        ;;
      --identity)
        require_option_value "$topic" "--identity" "${2:-}"
        apply_identity "$2"
        shift 2
        ;;
      --dry-run)
        dry_run=true
        shift
        ;;
      -h|--help)
        cmd_help "$topic"
        return 0
        ;;
      *)
        die_with_help "$topic" "Unknown argument '$1'."
        ;;
    esac
  done

  [ -n "$agent_type" ] || die_with_help "$topic" "Agent type required."
  [ -n "$name" ] && validate_name_component "$name" "Container name"
  validate_pids_limit "$pids_limit"
  if [ ${#repos[@]} -gt 0 ]; then
    ensure_ssh_for_repos "$enable_ssh" "${repos[@]}"
  else
    ensure_ssh_for_repos "$enable_ssh"
  fi

  require_cmd orb
  require_vm
  ensure_vm_runtime_hardening
  if ! $dry_run; then
    ensure_local_image_present
  fi

  timestamp=$(date +%s)
  if [ ${#repos[@]} -gt 0 ]; then
    container_name=$(resolve_container_name "${CONTAINER_PREFIX}-${agent_type}" "$name" "$timestamp" "${repos[@]}")
    repo_display=$(repo_display_label "${repos[@]}")
  else
    container_name=$(resolve_container_name "${CONTAINER_PREFIX}-${agent_type}" "$name" "$timestamp")
    repo_display="-"
  fi
  if [ ${#repos[@]} -gt 0 ]; then
    repos_joined=$(IFS=','; echo "${repos[*]}")
  fi

  prepare_network "$managed_network" "$container_name" "$custom_network_name" "$dry_run"

  if $managed_network; then
    network_mode_label="managed"
  elif [ "$network_name" = "none" ]; then
    network_mode_label="none"
  else
    network_mode_label="custom"
  fi

  info "Spawning $agent_type agent: $container_name"
  [ -n "$repos_joined" ] && info "Repo: $repo_display"
  if $managed_network; then
    info "Network: $network_name ($(managed_network_summary))"
  else
    info "Network: $network_name ($(custom_network_summary "$network_name"))"
  fi

  build_container_runtime "$container_name" "$agent_type" "$repos_joined" "$enable_ssh" "$network_name" "$memory" "$cpus" "$pids_limit" "$repo_display" "$network_mode_label"

  if $reuse_auth; then
    auth_volume_name="agent-${agent_type}-auth"
    if auth_volume_exists "$auth_volume_name"; then
      info "Auth: shared volume reused ($auth_volume_name)"
    else
      info "Auth: shared volume will be created ($auth_volume_name)"
    fi
    append_named_volume "$auth_volume_name" "/home/agent/.${agent_type}"
    docker_cmd+=(--label "safe-agentic.auth=shared")
  else
    info "Auth: per-session (ephemeral)"
    append_ephemeral_volume "/home/agent/.${agent_type}"
    docker_cmd+=(--label "safe-agentic.auth=ephemeral")
  fi

  docker_cmd+=("$IMAGE_NAME:$IMAGE_TAG")

  if $dry_run; then
    show_dry_run "$managed_network" "$network_name"
    return 0
  fi

  run_container "$managed_network" "$network_name"
}

cmd_shell() {
  local topic="shell"
  local -a repos=()
  local enable_ssh="$DEFAULT_SSH"
  local custom_network_name="$DEFAULT_NETWORK"
  local memory="$DEFAULT_MEMORY"
  local cpus="$DEFAULT_CPUS"
  local pids_limit="$DEFAULT_PIDS_LIMIT"
  local managed_network=true
  local network_name=""
  local dry_run=false
  local timestamp container_name repos_joined="" repo_display network_mode_label

  [ -n "$custom_network_name" ] && managed_network=false

  while [ $# -gt 0 ]; do
    case "$1" in
      --repo)
        require_option_value "$topic" "--repo" "${2:-}"
        repos+=("$2")
        shift 2
        ;;
      --ssh)
        enable_ssh=true
        shift
        ;;
      --network)
        require_option_value "$topic" "--network" "${2:-}"
        custom_network_name="$2"
        managed_network=false
        shift 2
        ;;
      --memory)
        require_option_value "$topic" "--memory" "${2:-}"
        memory="$2"
        shift 2
        ;;
      --cpus)
        require_option_value "$topic" "--cpus" "${2:-}"
        cpus="$2"
        shift 2
        ;;
      --pids-limit)
        require_option_value "$topic" "--pids-limit" "${2:-}"
        pids_limit="$2"
        shift 2
        ;;
      --identity)
        require_option_value "$topic" "--identity" "${2:-}"
        apply_identity "$2"
        shift 2
        ;;
      --dry-run)
        dry_run=true
        shift
        ;;
      -h|--help)
        cmd_help "$topic"
        return 0
        ;;
      *)
        die_with_help "$topic" "Unknown argument '$1'."
        ;;
    esac
  done

  validate_pids_limit "$pids_limit"
  if [ ${#repos[@]} -gt 0 ]; then
    ensure_ssh_for_repos "$enable_ssh" "${repos[@]}"
  else
    ensure_ssh_for_repos "$enable_ssh"
  fi

  require_cmd orb
  require_vm
  ensure_vm_runtime_hardening
  if ! $dry_run; then
    ensure_local_image_present
  fi

  timestamp=$(date +%s)
  if [ ${#repos[@]} -gt 0 ]; then
    container_name=$(resolve_container_name "${CONTAINER_PREFIX}-shell" "" "$timestamp" "${repos[@]}")
    repo_display=$(repo_display_label "${repos[@]}")
  else
    container_name=$(resolve_container_name "${CONTAINER_PREFIX}-shell" "" "$timestamp")
    repo_display="-"
  fi
  if [ ${#repos[@]} -gt 0 ]; then
    repos_joined=$(IFS=','; echo "${repos[*]}")
  fi

  prepare_network "$managed_network" "$container_name" "$custom_network_name" "$dry_run"

  if $managed_network; then
    network_mode_label="managed"
  elif [ "$network_name" = "none" ]; then
    network_mode_label="none"
  else
    network_mode_label="custom"
  fi

  info "Starting interactive shell: $container_name"
  [ -n "$repos_joined" ] && info "Repo: $repo_display"
  if $managed_network; then
    info "Network: $network_name ($(managed_network_summary))"
  else
    info "Network: $network_name ($(custom_network_summary "$network_name"))"
  fi

  build_container_runtime "$container_name" "" "$repos_joined" "$enable_ssh" "$network_name" "$memory" "$cpus" "$pids_limit" "$repo_display" "$network_mode_label"
  docker_cmd+=(--label "safe-agentic.auth=none")
  docker_cmd+=("$IMAGE_NAME:$IMAGE_TAG")

  if $dry_run; then
    show_dry_run "$managed_network" "$network_name"
    return 0
  fi

  run_container "$managed_network" "$network_name"
}

cmd_list() {
  require_vm
  vm_exec docker ps \
    --filter "name=^${CONTAINER_PREFIX}-" \
    --format 'table {{.Names}}\t{{.Label "safe-agentic.agent-type"}}\t{{.Label "safe-agentic.repo-display"}}\t{{.Label "safe-agentic.ssh"}}\t{{.Label "safe-agentic.auth"}}\t{{.Label "safe-agentic.network-mode"}}\t{{.Status}}'
}

resolve_target_container() {
  local topic="$1"
  local name="$2"
  local latest="$3"
  local resolved=""

  if $latest; then
    resolved=$(resolve_latest_container)
    [ -n "$resolved" ] || die "No running agent containers."
    printf '%s\n' "$resolved"
    return 0
  fi

  [ -n "$name" ] || die_with_help "$topic" "Container name required."
  validate_name_component "$name" "Container name"
  resolved=$(resolve_container_reference "$name" || true)
  [ -n "$resolved" ] || die "No running agent container matches '$name'."
  printf '%s\n' "$resolved"
}

cmd_attach() {
  local topic="attach"
  local name=""
  local latest=false

  while [ $# -gt 0 ]; do
    case "$1" in
      --latest)
        latest=true
        shift
        ;;
      -h|--help)
        cmd_help "$topic"
        return 0
        ;;
      *)
        [ -z "$name" ] || die_with_help "$topic" "Unexpected argument '$1'."
        name="$1"
        shift
        ;;
    esac
  done

  $latest && [ -n "$name" ] && die_with_help "$topic" "Use a name or --latest, not both."

  require_vm
  name=$(resolve_target_container "$topic" "$name" "$latest")

  info "Attaching to $name..."
  orb run -m "$VM_NAME" docker exec -it "$name" bash -l
}

cmd_stop() {
  local topic="stop"
  local name=""
  local latest=false
  local stop_all=false

  while [ $# -gt 0 ]; do
    case "$1" in
      --all)
        stop_all=true
        shift
        ;;
      --latest)
        latest=true
        shift
        ;;
      -h|--help)
        cmd_help "$topic"
        return 0
        ;;
      *)
        [ -z "$name" ] || die_with_help "$topic" "Unexpected argument '$1'."
        name="$1"
        shift
        ;;
    esac
  done

  require_vm

  if $stop_all; then
    $latest && die_with_help "$topic" "Use --all or --latest, not both."
    [ -z "$name" ] || die_with_help "$topic" "Use a name or --all, not both."

    info "Stopping all agent containers..."
    local ids names
    ids=$(vm_exec docker ps -q --filter "name=^${CONTAINER_PREFIX}-" 2>/dev/null || echo "")
    names=$(vm_exec docker ps --format '{{.Names}}' --filter "name=^${CONTAINER_PREFIX}-" 2>/dev/null || echo "")
    if [ -n "$ids" ]; then
      vm_exec docker stop $ids >/dev/null
      while IFS= read -r container_name; do
        [ -n "$container_name" ] && remove_managed_network "$(network_name_for_container "$container_name")"
      done <<< "$names"
      ok "All agent containers stopped."
    else
      info "No running agent containers."
    fi
    return 0
  fi

  $latest && [ -n "$name" ] && die_with_help "$topic" "Use a name or --latest, not both."
  name=$(resolve_target_container "$topic" "$name" "$latest")

  info "Stopping $name..."
  vm_exec docker stop "$name" >/dev/null
  remove_managed_network "$(network_name_for_container "$name")"
  ok "$name stopped."
}

cmd_cleanup() {
  local topic="cleanup"
  local remove_auth=false
  local running stopped managed_networks auth_vols

  while [ $# -gt 0 ]; do
    case "$1" in
      --auth)
        remove_auth=true
        shift
        ;;
      -h|--help)
        cmd_help "$topic"
        return 0
        ;;
      *)
        die_with_help "$topic" "Unknown argument '$1'."
        ;;
    esac
  done

  require_vm
  info "Cleaning up agent containers..."

  running=$(vm_exec docker ps -q --filter "name=^${CONTAINER_PREFIX}-" 2>/dev/null || echo "")
  if [ -n "$running" ]; then
    vm_exec docker stop $running >/dev/null
  fi

  stopped=$(vm_exec docker ps -aq --filter "name=^${CONTAINER_PREFIX}-" 2>/dev/null || echo "")
  if [ -n "$stopped" ]; then
    vm_exec docker rm $stopped >/dev/null
  fi

  managed_networks=$(vm_exec docker network ls -q \
    --filter "label=app=$IMAGE_NAME" \
    --filter "label=safe-agentic.type=container-network" 2>/dev/null || echo "")
  if [ -n "$managed_networks" ]; then
    vm_exec docker network rm $managed_networks >/dev/null 2>&1 || true
  fi

  if $remove_auth; then
    auth_vols=$(vm_exec docker volume ls -q 2>/dev/null | grep -E '^agent-(claude|codex)-auth$' || echo "")
    if [ -n "$auth_vols" ]; then
      vm_exec docker volume rm $auth_vols >/dev/null 2>&1 || true
    fi
  fi

  vm_exec docker image prune -f --filter "label=app=$IMAGE_NAME" >/dev/null 2>&1 || true
  if $remove_auth; then
    ok "Cleanup complete. Shared auth removed."
  else
    ok "Cleanup complete. Shared auth kept. Run 'agent cleanup --auth' to remove it."
  fi
}

cmd_update() {
  local topic="update"
  local quick=false
  local full=false
  local tarball
  local -a build_args=()

  while [ $# -gt 0 ]; do
    case "$1" in
      --quick)
        quick=true
        shift
        ;;
      --full)
        full=true
        shift
        ;;
      -h|--help)
        cmd_help "$topic"
        return 0
        ;;
      *)
        die_with_help "$topic" "Unknown argument '$1'."
        ;;
    esac
  done

  $quick && $full && die_with_help "$topic" "Use --quick or --full, not both."

  require_cmd orb
  require_cmd git
  require_vm
  ensure_vm_runtime_hardening

  info "[1/3] Preparing tracked build context..."
  tarball=$(mktemp -t safe-agentic-ctx)
  git -C "$REPO_DIR" ls-files -c -z \
    | ( cd "$REPO_DIR" && xargs -0 -I{} sh -c 'if test -e "$1"; then printf "%s\0" "$1"; fi' _ {} ) \
    | COPYFILE_DISABLE=1 tar -C "$REPO_DIR" --null -T - -czf "$tarball"

  info "[2/3] Syncing build context into VM..."
  vm_copy_from_host "$tarball" /tmp/safe-agentic-ctx.tar.gz
  vm_exec bash -c "rm -rf /tmp/safe-agentic && mkdir -p /tmp/safe-agentic && tar -xzf /tmp/safe-agentic-ctx.tar.gz -C /tmp/safe-agentic"
  rm -f "$tarball"
  sync_vm_seccomp_profile

  if $quick; then
    info "[3/3] Building image (quick CLI refresh; streaming logs)..."
    build_args+=(--build-arg "CLI_CACHE_BUST=$(date +%s)")
  elif $full; then
    info "[3/3] Building image (full rebuild; streaming logs)..."
    build_args+=(--no-cache)
  else
    info "[3/3] Building image (streaming logs)..."
  fi

  if [ ${#build_args[@]} -gt 0 ]; then
    vm_exec docker build --progress=plain "${build_args[@]}" -t "$IMAGE_NAME:$IMAGE_TAG" /tmp/safe-agentic/
  else
    vm_exec docker build --progress=plain -t "$IMAGE_NAME:$IMAGE_TAG" /tmp/safe-agentic/
  fi
  ok "Image $IMAGE_NAME:$IMAGE_TAG built successfully."
}

cmd_diagnose() {
  local failures=0
  local ssh_sock=""

  diag_ok()   { echo -e "${GREEN}[ok]${NC} $1"; }
  diag_warn() { echo -e "${YELLOW}[warn]${NC} $1"; }
  diag_fail() { echo -e "${RED}[fail]${NC} $1"; failures=$((failures + 1)); }

  if command -v orb >/dev/null 2>&1; then
    diag_ok "orb installed"
  else
    diag_fail "orb missing. Install OrbStack first."
    return 1
  fi

  if orb list >/dev/null 2>&1; then
    diag_ok "orb reachable"
  else
    diag_fail "orb not responding. Start OrbStack."
    return 1
  fi

  if orb list 2>/dev/null | grep -q "$VM_NAME"; then
    diag_ok "VM '$VM_NAME' exists"
  else
    diag_fail "VM '$VM_NAME' missing. Run 'agent setup'."
    return 1
  fi

  if vm_exec docker info >/dev/null 2>&1; then
    diag_ok "Docker reachable inside VM"
  else
    diag_fail "Docker unavailable inside VM. Re-run 'agent vm start' or 'agent setup'."
  fi

  if verify_vm_runtime_hardening >/dev/null 2>&1; then
    diag_ok "VM hardening verified"
  else
    diag_fail "VM hardening drift detected. Run 'agent vm start'."
  fi

  if vm_exec docker image inspect "$IMAGE_NAME:$IMAGE_TAG" >/dev/null 2>&1; then
    diag_ok "Image '$IMAGE_NAME:$IMAGE_TAG' present"
  else
    diag_fail "Image '$IMAGE_NAME:$IMAGE_TAG' missing. Run 'agent update'."
  fi

  ssh_sock=$(vm_exec bash -c 'echo "${SSH_AUTH_SOCK:-}"' 2>/dev/null || true)
  if [ -n "$ssh_sock" ]; then
    diag_ok "VM SSH agent socket visible: $ssh_sock"
  else
    diag_warn "No VM SSH agent socket. Private git@ repos need 1Password SSH agent + --ssh."
  fi

  if [ -f "$DEFAULTS_FILE" ]; then
    diag_ok "Defaults file loaded: $DEFAULTS_FILE"
  else
    diag_warn "No defaults file at $DEFAULTS_FILE"
  fi

  [ "$failures" -eq 0 ]
}

cmd_vm() {
  local topic="vm"
  local subcmd="${1:-}"

  case "$subcmd" in
    ssh)
      orb ssh "$VM_NAME"
      ;;
    stop)
      info "Stopping VM..."
      orb stop "$VM_NAME"
      ok "VM stopped."
      ;;
    start)
      info "Starting VM..."
      orb start "$VM_NAME"
      info "Re-applying VM hardening..."
      reapply_vm_runtime_hardening
      ok "VM started and hardened."
      ;;
    -h|--help)
      cmd_help "$topic"
      ;;
    "")
      die_with_help "$topic" "Subcommand required."
      ;;
    *)
      die_with_help "$topic" "Unknown subcommand '$subcmd'."
      ;;
  esac
}

cmd_help() {
  local topic="${1:-}"

  case "$topic" in
    ""|help)
      print_help_general
      ;;
    spawn)
      print_help_spawn
      ;;
    shell)
      print_help_shell
      ;;
    attach)
      print_help_attach
      ;;
    stop)
      print_help_stop
      ;;
    cleanup)
      print_help_cleanup
      ;;
    update)
      print_help_update
      ;;
    vm)
      print_help_vm
      ;;
    diagnose)
      print_help_diagnose
      ;;
    *)
      die "Unknown help topic: $topic. Run 'agent help' for available topics."
      ;;
  esac
}

cmd="${1:-help}"
shift 2>/dev/null || true

case "$cmd" in
  setup)    cmd_setup "$@" ;;
  spawn)    cmd_spawn "$@" ;;
  shell)    cmd_shell "$@" ;;
  list)     cmd_list "$@" ;;
  attach)   cmd_attach "$@" ;;
  stop)     cmd_stop "$@" ;;
  cleanup)  cmd_cleanup "$@" ;;
  update)   cmd_update "$@" ;;
  diagnose) cmd_diagnose "$@" ;;
  vm)       cmd_vm "$@" ;;
  help|-h|--help) cmd_help "$@" ;;
  *)        die "Unknown command: $cmd. Run 'agent help' for usage." ;;
esac
