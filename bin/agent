# cmd_dashboard — Start web dashboard
# ---------------------------------------------------------------------------
cmd_dashboard() {
  local topic="dashboard"

  while [ $# -gt 0 ]; do
    case "$1" in
      -h|--help)
        print_help_dashboard
        return 0
        ;;
      *)
        break
        ;;
    esac
  done

  die "The 'dashboard' command is not yet implemented. Coming in a future release."
}

print_help_retry() {
  cat <<EOF
Usage: agent retry <name>|--latest [--feedback "text"]

Stop the current container and spawn a fresh one with the same configuration.
If --feedback is provided, appends it to the original prompt so the agent
can try a different approach.

Options:
  --latest           Target the most recently started container
  --feedback TEXT    Append feedback to the original prompt
  -h, --help

Examples:
  agent retry my-task
  agent retry --latest
  agent retry --latest --feedback "The tests still fail -- look at the auth module"
EOF
}

cmd_retry() {
  local topic="retry"
  local name=""
  local latest=false
  local feedback=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --latest)
        latest=true
        shift
        ;;
      --feedback)
        require_option_value "$topic" "--feedback" "${2:-}"
        feedback="$2"
        shift 2
        ;;
      -h|--help)
        print_help_retry
        return 0
        ;;
      *)
        [ -z "$name" ] || die_with_help "$topic" "Unexpected argument '$1'."
        name="$1"
        shift
        ;;
    esac
  done

  $latest && [ -n "$name" ] && die_with_help "$topic" "Use a name or --latest, not both."

  if ! $latest && [ -z "$name" ]; then
    die_with_help "$topic" "Container name or --latest required."
  fi

  require_vm
  name=$(resolve_target_container "$topic" "$name" "$latest")

  # Read spawn configuration from Docker labels
  local agent_type ssh_label reuse_auth_label prompt_b64 max_cost_label aws_label
  agent_type=$(vm_exec docker inspect --format '{{index .Config.Labels "safe-agentic.agent-type"}}' "$name" 2>/dev/null || echo "")
  ssh_label=$(vm_exec docker inspect --format '{{index .Config.Labels "safe-agentic.ssh"}}' "$name" 2>/dev/null || echo "")
  reuse_auth_label=$(vm_exec docker inspect --format '{{index .Config.Labels "safe-agentic.auth"}}' "$name" 2>/dev/null || echo "")
  prompt_b64=$(vm_exec docker inspect --format '{{index .Config.Labels "safe-agentic.prompt"}}' "$name" 2>/dev/null || echo "")
  max_cost_label=$(vm_exec docker inspect --format '{{index .Config.Labels "safe-agentic.max-cost"}}' "$name" 2>/dev/null || echo "")
  aws_label=$(vm_exec docker inspect --format '{{index .Config.Labels "safe-agentic.aws"}}' "$name" 2>/dev/null || echo "")

  [ -n "$agent_type" ] || die "Could not determine agent type from container $name. Was it spawned with 'agent spawn'?"

  # Reconstruct original prompt from label
  local original_prompt=""
  if [ -n "$prompt_b64" ]; then
    original_prompt=$(printf '%s' "$prompt_b64" | base64 -d 2>/dev/null || echo "")
  fi

  # Build new prompt: original + feedback
  local new_prompt="$original_prompt"
  if [ -n "$feedback" ]; then
    if [ -n "$original_prompt" ]; then
      new_prompt="${original_prompt}

Previous attempt failed. Feedback: ${feedback}. Try a different approach."
    else
      new_prompt="Feedback: ${feedback}. Try a different approach."
    fi
  fi

  # Read env vars we need to reconstruct (instructions, on-exit)
  local all_envs instructions_b64_val on_exit_b64_val repos_env
  all_envs=$(vm_exec docker inspect --format '{{range .Config.Env}}{{println .}}{{end}}' "$name" 2>/dev/null || echo "")
  instructions_b64_val=$(printf '%s\n' "$all_envs" | grep '^SAFE_AGENTIC_INSTRUCTIONS_B64=' | cut -d= -f2- || echo "")
  on_exit_b64_val=$(printf '%s\n' "$all_envs" | grep '^SAFE_AGENTIC_ON_EXIT_B64=' | cut -d= -f2- || echo "")
  repos_env=$(printf '%s\n' "$all_envs" | grep '^REPOS=' | cut -d= -f2- || echo "")

  info "Stopping $name..."
  vm_exec docker stop "$name" >/dev/null 2>&1 || true
  vm_exec docker rm "$name" >/dev/null 2>&1 || true
  remove_docker_runtime_for_container "$name"
  remove_managed_network "$(network_name_for_container "$name")"
  audit_log "stop" "$name" "reason=retry"

  # Build new spawn args
  local -a spawn_args=("$agent_type")

  # Reconstruct repos
  if [ -n "$repos_env" ]; then
    local IFS_ORIG="$IFS"
    IFS=',' read -ra retry_repos <<< "$repos_env"
    IFS="$IFS_ORIG"
    local retry_repo
    for retry_repo in "${retry_repos[@]}"; do
      retry_repo=$(printf '%s' "$retry_repo" | xargs)
      [ -n "$retry_repo" ] && spawn_args+=(--repo "$retry_repo")
    done
  fi

  [ "$ssh_label" = "on" ] && spawn_args+=(--ssh)
  [ "$reuse_auth_label" = "shared" ] && spawn_args+=(--reuse-auth)
  [ -n "$aws_label" ] && spawn_args+=(--aws "$aws_label")

  if [ -n "$new_prompt" ]; then
    spawn_args+=(--prompt "$new_prompt")
  fi

  if [ -n "$instructions_b64_val" ]; then
    local decoded_instructions
    decoded_instructions=$(printf '%s' "$instructions_b64_val" | base64 -d 2>/dev/null || echo "")
    [ -n "$decoded_instructions" ] && spawn_args+=(--instructions "$decoded_instructions")
  fi

  if [ -n "$on_exit_b64_val" ]; then
    local decoded_on_exit
    decoded_on_exit=$(printf '%s' "$on_exit_b64_val" | base64 -d 2>/dev/null || echo "")
    [ -n "$decoded_on_exit" ] && spawn_args+=(--on-exit "$decoded_on_exit")
  fi

  [ -n "$max_cost_label" ] && spawn_args+=(--max-cost "$max_cost_label")

  info "Retrying as new container (type=$agent_type)..."
  [ -n "$new_prompt" ] && info "Prompt: ${new_prompt:0:80}$([ ${#new_prompt} -gt 80 ] && echo '...')"

  cmd_spawn "${spawn_args[@]}"
  audit_log "retry" "$name" "type=$agent_type"
}

cmd="${1:-help}"
shift 2>/dev/null || true

case "$cmd" in
  setup)      cmd_setup "$@" ;;
  spawn)      cmd_spawn "$@" ;;
  shell)      cmd_shell "$@" ;;
  list)       cmd_list "$@" ;;
  attach)     cmd_attach "$@" ;;
  cp)         cmd_cp "$@" ;;
  stop)       cmd_stop "$@" ;;
  cleanup)    cmd_cleanup "$@" ;;
  update)     cmd_update "$@" ;;
  diagnose)   cmd_diagnose "$@" ;;
  vm)         cmd_vm "$@" ;;
  mcp-login)  cmd_mcp_login "$@" ;;
  sessions)   cmd_sessions "$@" ;;
  peek)       cmd_peek "$@" ;;
  diff)       cmd_diff "$@" ;;
  checkpoint) cmd_checkpoint "$@" ;;
  todo)        cmd_todo "$@" ;;
  review)     cmd_review "$@" ;;
  audit)       cmd_audit "$@" ;;
  output)     cmd_output "$@" ;;
  cost)       cmd_cost "$@" ;;
  fleet)      cmd_fleet "$@" ;;
  pipeline)   cmd_pipeline "$@" ;;
  orchestrate) cmd_orchestrate "$@" ;;
  pr)         cmd_pr "$@" ;;
  aws-refresh) cmd_aws_refresh "$@" ;;
  config)      cmd_config "$@" ;;
  summary)     cmd_summary "$@" ;;
  retry)       cmd_retry "$@" ;;
  template)    cmd_template "$@" ;;
  run)         cmd_run "$@" ;;
  replay)      cmd_replay "$@" ;;
  dashboard)   cmd_dashboard "$@" ;;
  tui)
    tui_bin="$REPO_DIR/tui/agent-tui"
    [ -x "$tui_bin" ] || die "TUI not built. Run 'make -C $REPO_DIR/tui build' first."
    exec "$tui_bin" "$@"
    ;;
  --version)  echo "safe-agentic $VERSION"; exit 0 ;;
  help|-h|--help) cmd_help "$@" ;;
  *)          die "Unknown command: $cmd. Run 'agent help' for usage." ;;
esac
