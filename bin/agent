  --repo URL
  --ssh
  --reuse-gh-auth
  --docker
  --docker-socket
  --network NAME
  --memory SIZE
  --cpus N
  --pids-limit N
  --identity 'Name <email@example.com>'
  --dry-run
  -h, --help
EOF
}

