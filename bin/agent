#!/usr/bin/env bash
set -euo pipefail

REPO_DIR="$(cd "$(dirname "$(realpath "$0")")/.." && pwd)"
VERSION="dev"
IMAGE_NAME="safe-agentic"
IMAGE_TAG="latest"
CONTAINER_PREFIX="agent"
VM_NAME="safe-agentic"

RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
NC='\033[0m'

info()  { echo -e "${CYAN}[agent]${NC} $*"; }
ok()    { echo -e "${GREEN}[agent]${NC} $*"; }
warn()  { echo -e "${YELLOW}[agent]${NC} $*"; }
err()   { echo -e "${RED}[agent]${NC} $*" >&2; }
die()   { err "$@"; exit 1; }

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "'$1' is required but not installed."
}

require_vm() {
  orb list 2>/dev/null | grep -q "$VM_NAME" || die "VM '$VM_NAME' not found. Run 'agent setup' first."
}

vm_exec() {
  orb run -m "$VM_NAME" "$@"
}

vm_copy_from_host() {
  local source_path="$1"
  local destination_path="$2"

  [ -f "$source_path" ] || die "Local file not found: $source_path"
  # shellcheck disable=SC2016
  orb run -m "$VM_NAME" env DEST="$destination_path" bash -c 'cat > "$DEST"' < "$source_path"
}

source "$REPO_DIR/bin/agent-lib.sh"
# shellcheck disable=SC1091
source "$REPO_DIR/bin/docker-runtime.sh"

load_user_defaults
apply_default_identity

DEFAULT_CPUS="${SAFE_AGENTIC_DEFAULT_CPUS:-4}"
DEFAULT_MEMORY="${SAFE_AGENTIC_DEFAULT_MEMORY:-8g}"
DEFAULT_PIDS_LIMIT="${SAFE_AGENTIC_DEFAULT_PIDS_LIMIT:-512}"
DEFAULT_NETWORK="${SAFE_AGENTIC_DEFAULT_NETWORK:-}"
DEFAULT_REUSE_AUTH=false
DEFAULT_REUSE_GH_AUTH=false
DEFAULT_SSH=false
DEFAULT_DOCKER=false
DEFAULT_DOCKER_SOCKET=false

bool_is_true "${SAFE_AGENTIC_DEFAULT_REUSE_AUTH:-}" && DEFAULT_REUSE_AUTH=true
bool_is_true "${SAFE_AGENTIC_DEFAULT_REUSE_GH_AUTH:-}" && DEFAULT_REUSE_GH_AUTH=true
bool_is_true "${SAFE_AGENTIC_DEFAULT_SSH:-}" && DEFAULT_SSH=true
bool_is_true "${SAFE_AGENTIC_DEFAULT_DOCKER:-}" && DEFAULT_DOCKER=true
bool_is_true "${SAFE_AGENTIC_DEFAULT_DOCKER_SOCKET:-}" && DEFAULT_DOCKER_SOCKET=true

die_with_help() {
  local topic="$1"
  shift

  die "$*. Run 'agent help${topic:+ $topic}' for usage."
}

require_option_value() {
  local topic="$1"
  local flag="$2"
  local value="${3:-}"

  [ -n "$value" ] || die_with_help "$topic" "Missing value for $flag."
}

print_help_general() {
  cat <<EOF
${CYAN}safe-agentic${NC} — isolated AI agent environment

${GREEN}Setup:${NC}
  agent setup
  agent diagnose

${GREEN}Run:${NC}
  agent spawn <claude|codex> [options]
  agent run <repo> "prompt"                     (quick start with smart defaults)
  agent shell [options]
  agent-claude [spawn-options] <repo-url> [repo-url...]
  agent-codex [spawn-options] <repo-url> [repo-url...]

${GREEN}Manage:${NC}
  agent list [--json]
  agent summary <name>|--latest
  agent config <show|set|get|reset>
  agent tui
  agent dashboard [--bind HOST:PORT]              (web dashboard)
  agent attach <name>|--latest
  agent cp <name>|--latest <container-path> <host-path>
  agent peek <name>|--latest [--lines N]
  agent diff <name>|--latest [--stat]
  agent checkpoint <create|list|revert|fork> <name>|--latest [...]
  agent todo <add|list|check|uncheck> <name>|--latest [...]
  agent stop <name>|--latest|--all
  agent cleanup [--auth]
  agent retry <name>|--latest [--feedback "text"]

${GREEN}Observe:${NC}
  agent output <name>|--latest [--diff|--files|--commits|--json]
  agent review <name>|--latest [--base BRANCH]
  agent cost <name>|--latest [--history [PERIOD]]
  agent replay <name>|--latest                    (replay session from event log)

${GREEN}Analytics:${NC}
  agent audit [--lines N]

${GREEN}Orchestrate:${NC}
  agent fleet <manifest.yaml> [--dry-run]
  agent fleet status                                (show running fleet progress)
  agent pipeline <pipeline.yaml> [--dry-run]

${GREEN}Workflow:${NC}
  agent pr <name>|--latest [--title TITLE] [--base BRANCH]

${GREEN}AWS:${NC}
  agent aws-refresh <name>|--latest [profile]

${GREEN}Templates:${NC}
  agent template list
  agent template show <name>
  agent template create <name>

${GREEN}Maintain:${NC}
  agent update [--quick|--full]
  agent vm <ssh|stop|start>

${GREEN}Help:${NC}
  agent help [spawn|run|shell|attach|peek|diff|checkpoint|todo|cp|output|review|cost|audit|fleet|pipeline|pr|retry|stop|cleanup|update|vm|diagnose|config|summary|template|replay|dashboard|orchestrate]
  agent help <keyword>  (search all help text)

${GREEN}Examples:${NC}
  agent-claude git@github.com:myorg/myrepo.git
  agent run git@github.com:myorg/myrepo.git "Fix the CI tests"
  agent spawn codex --reuse-auth --identity 'You <you@example.com>' --repo https://github.com/myorg/api.git
  agent shell --dry-run --repo https://github.com/myorg/myrepo.git
  agent fleet agents.yaml --dry-run
  agent pipeline my-workflow.yaml --dry-run
  agent spawn claude --ssh --template security-audit --repo git@github.com:org/repo.git
EOF
}

print_help_spawn() {
  cat <<EOF
Usage: agent spawn <claude|codex> [options]

Options:
  --repo URL
  --name NAME
  --ssh
  --reuse-auth
  --reuse-gh-auth
  --docker
  --docker-socket
  --network NAME
  --memory SIZE
  --cpus N
  --pids-limit N
  --prompt 'TASK'
  --template NAME
  --instructions 'TEXT'
  --instructions-file PATH
  --on-exit 'COMMAND'
  --on-complete 'COMMAND'
  --on-fail 'COMMAND'
  --notify TARGETS
  --max-cost N
  --aws PROFILE
  --identity 'Name <email@example.com>'
  --ephemeral-auth
  --auto-trust
  --background
  --dry-run
  -h, --help

Notes:
  - --prompt sends an initial task to the agent (claude -p / codex positional arg)
  - --template loads a pre-built prompt by name (see 'agent template list'); --prompt takes precedence
  - --instructions injects text as /workspace/AGENT-INSTRUCTIONS.md (Claude picks it up automatically)
  - --instructions-file reads instructions from a local file
  - --on-exit runs a shell command after the agent exits (regardless of outcome)
  - --on-complete runs a shell command only when the agent succeeds (exit 0)
  - --on-fail runs a shell command only when the agent fails (non-zero exit)
  - --notify sends notifications to targets (comma-separated: terminal,slack,command:/path/to/script)
  - --max-cost sets a cost budget; kills the agent if estimated spend exceeds this amount
  - --ephemeral-auth forces a one-off auth volume (opposite of --reuse-auth)
  - --auto-trust skips the "trust this project?" prompt (useful for fleet/pipeline)
  - --background runs headless (no tmux, not attachable, output via docker logs)
  - Codex background runs require existing auth in --reuse-auth; otherwise first-run device login blocks in logs
  - --aws injects credentials from ~/.aws/credentials for the given profile
  - Default network: managed bridge with private/local egress blocked; TCP 22/80/443 only
  - Defaults file: ${DEFAULTS_FILE}
  - SSH repos require --ssh; aliases auto-enable it
  - --docker starts an internal Docker daemon sidecar
  - --docker-socket mounts the VM Docker socket directly (dangerous)
EOF
}

print_help_run() {
  cat <<EOF
Usage: agent run <repo> "prompt" [options]

Quick start with smart defaults. Equivalent to:
  agent spawn claude --ssh --reuse-auth --repo <repo> --prompt "prompt"

Automatically enables --ssh for SSH URLs and --reuse-auth for shared
credentials. Use 'agent spawn' for full control over flags.

Options:
  --type <claude|codex>   Agent type (default: claude)
  --name NAME             Container name override
  --on-complete 'CMD'     Run command on success
  --on-fail 'CMD'         Run command on failure
  --notify TARGETS        Send notifications (terminal,slack,command:script)
  --max-cost N            Kill agent if estimated cost exceeds budget
  -h, --help

Examples:
  agent run git@github.com:org/repo.git "Fix the failing CI tests"
  agent run https://github.com/org/repo.git "Add unit tests" --type codex
  agent run git@github.com:org/repo.git "Refactor auth" --on-complete "echo done"
EOF
}

