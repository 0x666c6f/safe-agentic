print_help_pipeline() {
  cat <<EOF
Usage: agent pipeline <pipeline.yaml> [--dry-run]

Execute a multi-step agent workflow defined in a YAML file.

Pipeline YAML format:
  name: my-pipeline
  steps:
    - name: step-name
      type: claude|codex
      repo: git@github.com:org/repo.git
      prompt: "Task description"
      ssh: true|false
      reuse_auth: true|false
      on_failure: other-step-name
      retry: N
      depends_on: step-name

Options:
  --dry-run   Print execution plan without running any agents

Step fields:
  name        Required. Unique step identifier.
  type        Agent type: claude (default) or codex.
  repo        Repository URL to clone.
  prompt      Initial task prompt for the agent.
  ssh         Enable SSH agent forwarding (default: false).
  reuse_auth  Reuse shared auth volume (default: false).
  on_failure  Step name to run if this step fails.
  retry       Number of retry attempts on failure (default: 0).
  depends_on  Step name that must have completed successfully.

Examples:
  agent pipeline workflow.yaml
  agent pipeline workflow.yaml --dry-run
EOF
}

