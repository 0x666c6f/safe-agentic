#!/usr/bin/env bash
set -euo pipefail

REPO_DIR="$(cd "$(dirname "$(realpath "$0")")/.." && pwd)"
IMAGE_NAME="safe-agentic"
IMAGE_TAG="latest"
CONTAINER_PREFIX="agent"
VM_NAME="safe-agentic"
DEFAULT_CPUS="4"
DEFAULT_MEMORY="8g"
DEFAULT_PIDS_LIMIT="512"

RED='\033[0;31m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[1;33m'
NC='\033[0m'

info()  { echo -e "${CYAN}[agent]${NC} $*"; }
ok()    { echo -e "${GREEN}[agent]${NC} $*"; }
warn()  { echo -e "${YELLOW}[agent]${NC} $*"; }
err()   { echo -e "${RED}[agent]${NC} $*" >&2; }
die()   { err "$@"; exit 1; }

require_cmd() {
  command -v "$1" >/dev/null 2>&1 || die "'$1' is required but not installed."
}

require_vm() {
  orb list 2>/dev/null | grep -q "$VM_NAME" || die "VM '$VM_NAME' not found. Run 'agent setup' first."
}

vm_exec() {
  orb run -m "$VM_NAME" "$@"
}

vm_copy_from_host() {
  local source_path="$1"
  local destination_path="$2"

  [ -f "$source_path" ] || die "Local file not found: $source_path"
  # Use env var to safely pass path without shell interpolation
  orb run -m "$VM_NAME" env DEST="$destination_path" bash -c 'cat > "$DEST"' < "$source_path"
}

source "$REPO_DIR/bin/agent-lib.sh"

cmd_setup() {
  info "Setting up safe-agentic environment..."

  require_cmd orb

  if orb list 2>/dev/null | grep -q "$VM_NAME"; then
    info "VM '$VM_NAME' already exists."
  else
    info "Creating OrbStack VM '$VM_NAME' (Ubuntu)..."
    orb create ubuntu "$VM_NAME"
    ok "VM created."
  fi

  orb start "$VM_NAME" 2>/dev/null || true

  info "Bootstrapping VM (installing Docker)..."
  reapply_vm_runtime_hardening

  cmd_update

  ok "Setup complete. Run 'agent spawn claude --repo <url>' to start."
}

cmd_spawn() {
  local agent_type=""
  local -a repos=()
  local name=""
  local enable_ssh=false
  local reuse_auth=false
  local custom_network_name=""
  local memory="$DEFAULT_MEMORY"
  local cpus="$DEFAULT_CPUS"
  local pids_limit="$DEFAULT_PIDS_LIMIT"
  local managed_network=true
  local network_name=""

  while [ $# -gt 0 ]; do
    case "$1" in
      claude|codex)
        agent_type="$1"; shift ;;
      --repo)
        shift; repos+=("$1"); shift ;;
      --name)
        shift; name="$1"; shift ;;
      --ssh)
        enable_ssh=true; shift ;;
      --reuse-auth)
        reuse_auth=true; shift ;;
      --network)
        shift; custom_network_name="$1"; managed_network=false; shift ;;
      --memory)
        shift; memory="$1"; shift ;;
      --cpus)
        shift; cpus="$1"; shift ;;
      --pids-limit)
        shift; pids_limit="$1"; shift ;;
      *)
        die "Unknown argument: $1. Usage: agent spawn <claude|codex> [--repo URL...] [--name NAME] [--ssh] [--reuse-auth] [--network NAME] [--memory SIZE] [--cpus N] [--pids-limit N]" ;;
    esac
  done

  [ -z "$agent_type" ] && die "Agent type required. Usage: agent spawn <claude|codex> [--repo URL...] [--ssh]"

  require_cmd orb
  require_vm
  ensure_vm_runtime_hardening
  ensure_local_image_present
  validate_pids_limit "$pids_limit"

  local timestamp
  timestamp=$(date +%s)
  [ -n "$name" ] && validate_name_component "$name" "Container name"
  local container_name="${CONTAINER_PREFIX}-${agent_type}-${name:-$timestamp}"
  local repos_joined=""

  if [ ${#repos[@]} -gt 0 ]; then
    repos_joined=$(IFS=','; echo "${repos[*]}")
  fi

  prepare_network "$managed_network" "$container_name" "$custom_network_name"

  info "Spawning $agent_type agent: $container_name"
  [ -n "$repos_joined" ] && info "Repos: $repos_joined"
  info "Network: $network_name"

  build_container_runtime "$container_name" "$agent_type" "$repos_joined" "$enable_ssh" "$network_name" "$memory" "$cpus" "$pids_limit"

  if $reuse_auth; then
    case "$agent_type" in
      claude) append_named_volume "agent-claude-auth" /home/agent/.claude ;;
      codex)  append_named_volume "agent-codex-auth" /home/agent/.codex ;;
    esac
    info "Auth: reusing shared session"
  else
    case "$agent_type" in
      claude) append_ephemeral_volume /home/agent/.claude ;;
      codex)  append_ephemeral_volume /home/agent/.codex ;;
    esac
    info "Auth: per-session (ephemeral)"
  fi

  docker_cmd+=("$IMAGE_NAME:$IMAGE_TAG")
  run_container "$managed_network" "$network_name"
}

cmd_shell() {
  local -a repos=()
  local enable_ssh=false
  local custom_network_name=""
  local memory="$DEFAULT_MEMORY"
  local cpus="$DEFAULT_CPUS"
  local pids_limit="$DEFAULT_PIDS_LIMIT"
  local managed_network=true
  local network_name=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --repo)
        shift; repos+=("$1"); shift ;;
      --ssh)
        enable_ssh=true; shift ;;
      --network)
        shift; custom_network_name="$1"; managed_network=false; shift ;;
      --memory)
        shift; memory="$1"; shift ;;
      --cpus)
        shift; cpus="$1"; shift ;;
      --pids-limit)
        shift; pids_limit="$1"; shift ;;
      *)
        die "Unknown argument: $1. Usage: agent shell [--repo URL...] [--ssh] [--network NAME] [--memory SIZE] [--cpus N] [--pids-limit N]" ;;
    esac
  done

  require_cmd orb
  require_vm
  ensure_vm_runtime_hardening
  ensure_local_image_present
  validate_pids_limit "$pids_limit"

  local timestamp
  timestamp=$(date +%s)
  local container_name="${CONTAINER_PREFIX}-shell-${timestamp}"
  local repos_joined=""

  if [ ${#repos[@]} -gt 0 ]; then
    repos_joined=$(IFS=','; echo "${repos[*]}")
  fi

  prepare_network "$managed_network" "$container_name" "$custom_network_name"

  info "Starting interactive shell: $container_name"
  info "Network: $network_name"

  build_container_runtime "$container_name" "" "$repos_joined" "$enable_ssh" "$network_name" "$memory" "$cpus" "$pids_limit"
  docker_cmd+=("$IMAGE_NAME:$IMAGE_TAG")
  run_container "$managed_network" "$network_name"
}

cmd_list() {
  require_vm
  vm_exec docker ps \
    --filter "name=^${CONTAINER_PREFIX}-" \
    --format "table {{.Names}}\t{{.Status}}\t{{.CreatedAt}}\t{{.Image}}"
}

cmd_attach() {
  local name="${1:-}"
  [ -z "$name" ] && die "Usage: agent attach <name>"
  validate_name_component "$name" "Container name"
  require_vm

  if [[ ! "$name" == ${CONTAINER_PREFIX}-* ]]; then
    name="${CONTAINER_PREFIX}-${name}"
  fi

  info "Attaching to $name..."
  orb run -m "$VM_NAME" docker exec -it "$name" bash -l
}

cmd_stop() {
  require_vm

  if [ "${1:-}" = "--all" ]; then
    info "Stopping all agent containers..."
    local ids
    local names
    ids=$(vm_exec docker ps -q --filter "name=^${CONTAINER_PREFIX}-" 2>/dev/null || echo "")
    names=$(vm_exec docker ps --format '{{.Names}}' --filter "name=^${CONTAINER_PREFIX}-" 2>/dev/null || echo "")
    if [ -n "$ids" ]; then
      vm_exec docker stop $ids >/dev/null
      while IFS= read -r container_name; do
        [ -n "$container_name" ] && remove_managed_network "$(network_name_for_container "$container_name")"
      done <<< "$names"
      ok "All agent containers stopped."
    else
      info "No running agent containers."
    fi
    return
  fi

  if [ -z "${1:-}" ]; then
    die "Usage: agent stop <name|--all>"
  fi

  local name="$1"
  validate_name_component "$name" "Container name"
  if [[ ! "$name" == ${CONTAINER_PREFIX}-* ]]; then
    name="${CONTAINER_PREFIX}-${name}"
  fi

  info "Stopping $name..."
  vm_exec docker stop "$name" >/dev/null
  remove_managed_network "$(network_name_for_container "$name")"
  ok "$name stopped."
}

cmd_cleanup() {
  require_vm
  info "Cleaning up agent containers..."

  local running
  running=$(vm_exec docker ps -q --filter "name=^${CONTAINER_PREFIX}-" 2>/dev/null || echo "")
  if [ -n "$running" ]; then
    vm_exec docker stop $running >/dev/null
  fi

  local stopped
  stopped=$(vm_exec docker ps -aq --filter "name=^${CONTAINER_PREFIX}-" 2>/dev/null || echo "")
  if [ -n "$stopped" ]; then
    vm_exec docker rm $stopped >/dev/null
  fi

  local auth_vols
  auth_vols=$(vm_exec docker volume ls -q 2>/dev/null | grep -E '^agent-(claude|codex)-auth$' || echo "")
  if [ -n "$auth_vols" ]; then
    vm_exec docker volume rm $auth_vols >/dev/null 2>&1 || true
  fi

  local managed_networks
  managed_networks=$(vm_exec docker network ls -q \
    --filter "label=app=$IMAGE_NAME" \
    --filter "label=safe-agentic.type=container-network" 2>/dev/null || echo "")
  if [ -n "$managed_networks" ]; then
    vm_exec docker network rm $managed_networks >/dev/null 2>&1 || true
  fi

  vm_exec docker image prune -f --filter "label=app=$IMAGE_NAME" >/dev/null 2>&1 || true
  ok "Cleanup complete."
}

cmd_update() {
  local quick=false
  local full=false

  while [ $# -gt 0 ]; do
    case "$1" in
      --quick) quick=true; shift ;;
      --full)  full=true; shift ;;
      *) die "Usage: agent update [--quick|--full]" ;;
    esac
  done

  if $quick && $full; then
    die "Usage: agent update [--quick|--full]"
  fi

  require_cmd orb
  require_cmd git
  require_vm
  ensure_vm_runtime_hardening

  info "Pushing build context to VM (tracked files only)..."
  local tarball
  tarball=$(mktemp -t safe-agentic-ctx)
  git -C "$REPO_DIR" ls-files -c -z \
    | ( cd "$REPO_DIR" && xargs -0 -I{} sh -c 'if test -e "$1"; then printf "%s\0" "$1"; fi' _ {} ) \
    | COPYFILE_DISABLE=1 tar -C "$REPO_DIR" --null -T - -czf "$tarball"
  vm_copy_from_host "$tarball" /tmp/safe-agentic-ctx.tar.gz
  vm_exec bash -c "rm -rf /tmp/safe-agentic && mkdir -p /tmp/safe-agentic && tar -xzf /tmp/safe-agentic-ctx.tar.gz -C /tmp/safe-agentic"
  rm -f "$tarball"

  sync_vm_seccomp_profile

  local -a build_args=()
  if $quick; then
    info "Quick update: rebuilding AI CLI layer only..."
    build_args+=(--build-arg "CLI_CACHE_BUST=$(date +%s)")
  elif $full; then
    info "Full rebuild: no cache..."
    build_args+=(--no-cache)
  else
    info "Building Docker image..."
  fi

  if [ ${#build_args[@]} -gt 0 ]; then
    vm_exec docker build "${build_args[@]}" -t "$IMAGE_NAME:$IMAGE_TAG" /tmp/safe-agentic/
  else
    vm_exec docker build -t "$IMAGE_NAME:$IMAGE_TAG" /tmp/safe-agentic/
  fi
  ok "Image $IMAGE_NAME:$IMAGE_TAG built successfully."
}

cmd_vm() {
  local subcmd="${1:-}"
  shift 2>/dev/null || true

  case "$subcmd" in
    ssh)
      orb ssh "$VM_NAME"
      ;;
    stop)
      info "Stopping VM..."
      orb stop "$VM_NAME"
      ok "VM stopped."
      ;;
    start)
      info "Starting VM..."
      orb start "$VM_NAME"
      info "Re-applying VM hardening..."
      reapply_vm_runtime_hardening
      ok "VM started and hardened."
      ;;
    *)
      die "Usage: agent vm <ssh|stop|start>"
      ;;
  esac
}

cmd_help() {
  cat <<EOF
${CYAN}safe-agentic${NC} — isolated AI agent environment

${GREEN}Setup:${NC}
  agent setup                  Create OrbStack VM, harden it, build image

${GREEN}Agent management:${NC}
  agent spawn <claude|codex> [options]
    --repo URL                 Repo(s) to clone (repeatable)
    --name NAME                Container name suffix
    --ssh                      Enable SSH agent forwarding
    --reuse-auth               Reuse shared auth volume
    --network NAME             Existing VM Docker network (default: dedicated bridge with egress guardrails)
    --memory SIZE              Docker memory limit (default: ${DEFAULT_MEMORY})
    --cpus N                   Docker CPU limit (default: ${DEFAULT_CPUS})
    --pids-limit N             Docker PID limit (default: ${DEFAULT_PIDS_LIMIT})
  agent shell [options]        Interactive shell; same network/resource flags
  agent list                   List running agent containers
  agent attach <name>          Second shell into running agent
  agent stop <name|--all>      Stop container(s)
  agent cleanup                Stop all, remove shared auth, prune managed networks

${GREEN}Maintenance:${NC}
  agent update [--quick|--full]

${GREEN}VM management:${NC}
  agent vm ssh
  agent vm stop
  agent vm start

${GREEN}Security defaults:${NC}
  - SSH forwarding off unless --ssh
  - Shared auth only with --reuse-auth
  - Read-only rootfs, all capabilities dropped, no-new-privileges
  - Dedicated per-container bridge network by default (private/local egress blocked; TCP 22/80/443 only)
  - Ephemeral workspace, auth, and cache volumes by default

${GREEN}Examples:${NC}
  agent setup
  agent spawn claude --repo https://github.com/myorg/myrepo.git
  agent spawn claude --ssh --repo git@github.com:myorg/myrepo.git
  agent spawn codex --ssh --reuse-auth --repo git@github.com:myorg/api.git --name api-fix
  agent spawn claude --repo https://github.com/myorg/a.git --network agent-isolated
  agent shell --repo https://github.com/myorg/myrepo.git --memory 12g
EOF
}

cmd="${1:-help}"
shift 2>/dev/null || true

case "$cmd" in
  setup)   cmd_setup "$@" ;;
  spawn)   cmd_spawn "$@" ;;
  shell)   cmd_shell "$@" ;;
  list)    cmd_list "$@" ;;
  attach)  cmd_attach "$@" ;;
  stop)    cmd_stop "$@" ;;
  cleanup) cmd_cleanup "$@" ;;
  update)  cmd_update "$@" ;;
  vm)      cmd_vm "$@" ;;
  help|-h|--help) cmd_help ;;
  *)       die "Unknown command: $cmd. Run 'agent help' for usage." ;;
esac
