}

cmd_setup() {
  require_cmd orb

  info "[1/3] Ensuring VM exists..."
  if orb list 2>/dev/null | grep -q "$VM_NAME"; then
    info "VM '$VM_NAME' already exists."
  else
    info "Creating OrbStack VM '$VM_NAME' (Ubuntu)..."
    orb create ubuntu "$VM_NAME"
    ok "VM created."
  fi

  orb start "$VM_NAME" 2>/dev/null || true

  info "[2/3] Bootstrapping VM runtime..."
  reapply_vm_runtime_hardening

  info "[3/3] Building safe-agentic image..."
  cmd_update

  ok "Setup complete. Try: agent-claude https://github.com/myorg/myrepo.git"
}

show_dry_run() {
  local managed_network="$1"
  local network_name="$2"

  info "Dry run only. No container started."
  if $managed_network; then
    local bridge_name
    bridge_name=$(bridge_name_for_network "$network_name")
    info "Would create network: $(render_command orb run -m "$VM_NAME" docker network create --driver bridge --opt "com.docker.network.bridge.name=$bridge_name" --opt com.docker.network.bridge.enable_icc=false --label "app=$IMAGE_NAME" --label "safe-agentic.type=container-network" "$network_name")"
  else
    info "Would use network: $network_name"
  fi
  if [ "${DOCKER_RUNTIME_KIND:-off}" = "dind" ]; then
    info "Would start Docker sidecar: $(render_command orb run -m "$VM_NAME" docker run -d --name "$DOCKER_RUNTIME_CONTAINER" --hostname "$DOCKER_RUNTIME_CONTAINER" --pull=never --privileged --user root --network "$network_name" --label "app=$IMAGE_NAME" --label "safe-agentic.type=docker-runtime" --label "safe-agentic.parent=$ACTIVE_CONTAINER_NAME" --mount "type=volume,src=$DOCKER_RUNTIME_SOCKET_VOLUME,dst=$DOCKER_INTERNAL_SOCKET_DIR" --mount "type=volume,src=$DOCKER_RUNTIME_DATA_VOLUME,dst=/var/lib/docker" --tmpfs /tmp:rw,nosuid,size=512m -e SAFE_AGENTIC_INTERNAL_DOCKERD=1 -e "SAFE_AGENTIC_DOCKER_SOCKET=$DOCKER_INTERNAL_SOCKET_PATH" -e SAFE_AGENTIC_DOCKER_DATA_ROOT=/var/lib/docker "$IMAGE_NAME:$IMAGE_TAG")"
  fi
  info "Would run: $(render_command orb run -m "$VM_NAME" "${docker_cmd[@]}")"
}

auto_attach_tmux_session() {
  local name="$1"

  if ! [ -t 0 ] || ! [ -t 1 ]; then
    info "Container started detached: $name"
    return 0
  fi

  info "Waiting for tmux session in $name..."
  if ! wait_for_tmux_session "$name"; then
    die "Timed out waiting for tmux session in $name. Check logs with: orb run -m $VM_NAME docker logs $name"
  fi

  info "Attaching to $name..."
  attach_tmux_session "$name"
}

attach_container_console() {
  local name="$1"
  local state="$2"
  local terminal_mode

  terminal_mode=$(trim_whitespace "$(container_terminal_mode "$name")")
  if [ "$state" = "running" ] && [ "$terminal_mode" = "tmux" ] && container_has_tmux_session "$name"; then
    attach_tmux_session "$name"
    return 0
  fi

  case "$state" in
    running)
      orb run -m "$VM_NAME" docker exec -it "$name" bash -l
      ;;
    exited|created)
      orb run -m "$VM_NAME" docker start -ai "$name"
      ;;
    *)
      die "Container $name is in state '$state' and cannot be attached."
      ;;
  esac
}

cmd_spawn() {
  local topic="spawn"
  local agent_type=""
  local -a repos=()
  local name=""
  local enable_ssh="$DEFAULT_SSH"
  local reuse_auth="$DEFAULT_REUSE_AUTH"
  local reuse_gh_auth="$DEFAULT_REUSE_GH_AUTH"
  local enable_docker="$DEFAULT_DOCKER"
  local use_docker_socket="$DEFAULT_DOCKER_SOCKET"
  local custom_network_name="$DEFAULT_NETWORK"
  local memory="$DEFAULT_MEMORY"
  local cpus="$DEFAULT_CPUS"
  local pids_limit="$DEFAULT_PIDS_LIMIT"
  local managed_network=true
  local network_name=""
  local dry_run=false
  local auto_trust=false
  local background=false
  local agent_prompt=""
  local aws_profile=""
  local timestamp container_name repos_joined="" repo_display network_mode_label auth_volume_name gh_auth_label docker_label

  [ -n "$custom_network_name" ] && managed_network=false

  while [ $# -gt 0 ]; do
    case "$1" in
      claude|codex)
        [ -z "$agent_type" ] || die_with_help "$topic" "Agent type already set to '$agent_type'."
        agent_type="$1"
        shift
        ;;
      --repo)
        require_option_value "$topic" "--repo" "${2:-}"
        repos+=("$2")
        shift 2
        ;;
      --name)
        require_option_value "$topic" "--name" "${2:-}"
        name="$2"
        shift 2
        ;;
      --prompt)
        require_option_value "$topic" "--prompt" "${2:-}"
        agent_prompt="$2"
        shift 2
        ;;
      --aws)
        require_option_value "$topic" "--aws" "${2:-}"
        aws_profile="$2"
        shift 2
        ;;
      --ssh)
        enable_ssh=true
        shift
        ;;
      --reuse-auth)
        reuse_auth=true
        shift
        ;;
      --reuse-gh-auth)
        reuse_gh_auth=true
        shift
        ;;
      --docker)
        enable_docker=true
        shift
        ;;
      --docker-socket)
        enable_docker=true
        use_docker_socket=true
        shift
        ;;
      --network)
        require_option_value "$topic" "--network" "${2:-}"
        custom_network_name="$2"
        managed_network=false
        shift 2
        ;;
      --memory)
        require_option_value "$topic" "--memory" "${2:-}"
        memory="$2"
        shift 2
        ;;
      --cpus)
        require_option_value "$topic" "--cpus" "${2:-}"
        cpus="$2"
        shift 2
        ;;
      --pids-limit)
        require_option_value "$topic" "--pids-limit" "${2:-}"
        pids_limit="$2"
        shift 2
        ;;
      --identity)
        require_option_value "$topic" "--identity" "${2:-}"
        apply_identity "$2"
        shift 2
        ;;
      --auto-trust)
        auto_trust=true
        shift
        ;;
      --background)
        background=true
        shift
        ;;
      --dry-run)
        dry_run=true
        shift
        ;;
      -h|--help)
        cmd_help "$topic"
        return 0
        ;;
      *)
        die_with_help "$topic" "Unknown argument '$1'."
        ;;
    esac
  done

  [ -n "$agent_type" ] || die_with_help "$topic" "Agent type required."
  [ -n "$name" ] && validate_name_component "$name" "Container name"
  validate_pids_limit "$pids_limit"
  $use_docker_socket && enable_docker=true
  if [ ${#repos[@]} -gt 0 ]; then
    ensure_ssh_for_repos "$enable_ssh" "${repos[@]}"
  else
    ensure_ssh_for_repos "$enable_ssh"
  fi

  require_cmd orb
  require_vm
  ensure_vm_runtime_hardening
  if ! $dry_run; then
    ensure_local_image_present
  fi

  timestamp=$(date +%s)
  if [ ${#repos[@]} -gt 0 ]; then
    container_name=$(resolve_container_name "${CONTAINER_PREFIX}-${agent_type}" "$name" "$timestamp" "${repos[@]}")
    repo_display=$(repo_display_label "${repos[@]}")
  else
    container_name=$(resolve_container_name "${CONTAINER_PREFIX}-${agent_type}" "$name" "$timestamp")
    repo_display="-"
  fi
  if [ ${#repos[@]} -gt 0 ]; then
    repos_joined=$(IFS=','; echo "${repos[*]}")
  fi

  prepare_network "$managed_network" "$container_name" "$custom_network_name" "$dry_run"

  if $managed_network; then
    network_mode_label="managed"
  elif [ "$network_name" = "none" ]; then
    network_mode_label="none"
  else
    network_mode_label="custom"
  fi

  info "Spawning $agent_type agent: $container_name"
  [ -n "$repos_joined" ] && info "Repo: $repo_display"
  if $managed_network; then
    info "Network: $network_name ($(managed_network_summary))"
  else
    info "Network: $network_name ($(custom_network_summary "$network_name"))"
  fi

  build_container_runtime "$container_name" "$agent_type" "$repos_joined" "$enable_ssh" "$network_name" "$memory" "$cpus" "$pids_limit" "$repo_display" "$network_mode_label"

  # Inject host agent config so MCP servers, model settings, etc. carry over
  inject_host_config "$agent_type"

  # Inject AWS credentials if requested
  if [ -n "$aws_profile" ]; then
    inject_aws_credentials "$aws_profile"
  fi

  if $reuse_auth; then
    auth_volume_name="agent-${agent_type}-auth"
    if auth_volume_exists "$auth_volume_name"; then
      info "Auth: shared volume reused ($auth_volume_name)"
    else
      info "Auth: shared volume will be created ($auth_volume_name)"
    fi
    append_named_volume "$auth_volume_name" "/home/agent/.${agent_type}"
    docker_cmd+=(--label "safe-agentic.auth=shared")
  else
    info "Auth: per-session (ephemeral)"
    append_ephemeral_volume "/home/agent/.${agent_type}"
    docker_cmd+=(--label "safe-agentic.auth=ephemeral")
  fi

  docker_cmd+=(-e "GH_CONFIG_DIR=/home/agent/.config/gh")
  if $reuse_gh_auth; then
    if auth_volume_exists "agent-gh-auth"; then
      info "GitHub CLI auth: shared volume reused (agent-gh-auth)"
    else
      info "GitHub CLI auth: shared volume will be created (agent-gh-auth)"
    fi
    append_named_volume "agent-gh-auth" "/home/agent/.config/gh"
    gh_auth_label="shared"
  else
    info "GitHub CLI auth: per-session (ephemeral)"
    gh_auth_label="ephemeral"
  fi
  docker_cmd+=(--label "safe-agentic.gh-auth=$gh_auth_label")

  reset_docker_runtime_state
  docker_label="off"
  if $enable_docker; then
    if $use_docker_socket; then
      info "Docker: VM daemon socket mounted directly (dangerous)"
      append_host_docker_socket_access
      docker_label="host-socket"
    else
      info "Docker: internal daemon sidecar (DinD)"
      append_internal_docker_access "$container_name"
      docker_label="dind"
    fi
  fi
  docker_cmd+=(--label "safe-agentic.docker=$docker_label")

  if $auto_trust; then
    docker_cmd+=(-e "SAFE_AGENTIC_AUTO_TRUST=1")
  fi

  if $background; then
    docker_cmd+=(-e "SAFE_AGENTIC_BACKGROUND=1")
    docker_cmd+=(--label "safe-agentic.terminal=none")
  else
    docker_cmd+=(--label "safe-agentic.terminal=tmux")
  fi

  docker_cmd+=("$IMAGE_NAME:$IMAGE_TAG")

  # Append agent prompt after image name (forwarded as entrypoint $@)
  if [ -n "$agent_prompt" ]; then
    case "$agent_type" in
      claude) docker_cmd+=(-p "$agent_prompt") ;;
      codex)  docker_cmd+=("$agent_prompt") ;;
    esac
    info "Prompt: ${agent_prompt:0:80}$([ ${#agent_prompt} -gt 80 ] && echo '...')"
  fi

  if $dry_run; then
    show_dry_run "$managed_network" "$network_name"
    return 0
  fi

  if [ "$DOCKER_RUNTIME_KIND" = "dind" ]; then
    start_internal_docker_runtime "$container_name" "$network_name"
  fi
  if [ "$agent_type" = "codex" ] || [ "$agent_type" = "claude" ]; then
    run_container_detached
    ok "Container: $container_name"
    audit_log "spawn" "$container_name" "type=$agent_type ssh=$enable_ssh auth=$( $reuse_auth && echo shared || echo ephemeral)"
    auto_attach_tmux_session "$container_name"
  else
    run_container "$managed_network" "$network_name"
    ok "Container: $container_name"
    audit_log "spawn" "$container_name" "type=$agent_type ssh=$enable_ssh auth=$( $reuse_auth && echo shared || echo ephemeral)"
  fi
}

cmd_shell() {
  local topic="shell"
  local -a repos=()
  local enable_ssh="$DEFAULT_SSH"
  local reuse_gh_auth="$DEFAULT_REUSE_GH_AUTH"
  local enable_docker="$DEFAULT_DOCKER"
  local use_docker_socket="$DEFAULT_DOCKER_SOCKET"
  local custom_network_name="$DEFAULT_NETWORK"
  local memory="$DEFAULT_MEMORY"
  local cpus="$DEFAULT_CPUS"
  local pids_limit="$DEFAULT_PIDS_LIMIT"
  local managed_network=true
  local network_name=""
  local dry_run=false
  local timestamp container_name repos_joined="" repo_display network_mode_label gh_auth_label docker_label

  [ -n "$custom_network_name" ] && managed_network=false

  while [ $# -gt 0 ]; do
    case "$1" in
      --repo)
        require_option_value "$topic" "--repo" "${2:-}"
        repos+=("$2")
        shift 2
        ;;
      --ssh)
        enable_ssh=true
        shift
        ;;
      --reuse-gh-auth)
        reuse_gh_auth=true
        shift
        ;;
      --docker)
        enable_docker=true
        shift
        ;;
      --docker-socket)
        enable_docker=true
        use_docker_socket=true
        shift
        ;;
      --network)
        require_option_value "$topic" "--network" "${2:-}"
        custom_network_name="$2"
        managed_network=false
        shift 2
        ;;
      --memory)
        require_option_value "$topic" "--memory" "${2:-}"
        memory="$2"
        shift 2
        ;;
      --cpus)
        require_option_value "$topic" "--cpus" "${2:-}"
        cpus="$2"
        shift 2
        ;;
      --pids-limit)
        require_option_value "$topic" "--pids-limit" "${2:-}"
        pids_limit="$2"
        shift 2
        ;;
      --identity)
        require_option_value "$topic" "--identity" "${2:-}"
        apply_identity "$2"
        shift 2
        ;;
      --dry-run)
        dry_run=true
        shift
        ;;
      -h|--help)
        cmd_help "$topic"
        return 0
        ;;
      *)
        die_with_help "$topic" "Unknown argument '$1'."
        ;;
    esac
  done

  validate_pids_limit "$pids_limit"
  $use_docker_socket && enable_docker=true
  if [ ${#repos[@]} -gt 0 ]; then
    ensure_ssh_for_repos "$enable_ssh" "${repos[@]}"
  else
    ensure_ssh_for_repos "$enable_ssh"
  fi

  require_cmd orb
  require_vm
  ensure_vm_runtime_hardening
  if ! $dry_run; then
    ensure_local_image_present
  fi

  timestamp=$(date +%s)
  if [ ${#repos[@]} -gt 0 ]; then
    container_name=$(resolve_container_name "${CONTAINER_PREFIX}-shell" "" "$timestamp" "${repos[@]}")
    repo_display=$(repo_display_label "${repos[@]}")
  else
    container_name=$(resolve_container_name "${CONTAINER_PREFIX}-shell" "" "$timestamp")
    repo_display="-"
  fi
  if [ ${#repos[@]} -gt 0 ]; then
    repos_joined=$(IFS=','; echo "${repos[*]}")
  fi

  prepare_network "$managed_network" "$container_name" "$custom_network_name" "$dry_run"

  if $managed_network; then
    network_mode_label="managed"
  elif [ "$network_name" = "none" ]; then
    network_mode_label="none"
  else
    network_mode_label="custom"
  fi

  info "Starting interactive shell: $container_name"
  [ -n "$repos_joined" ] && info "Repo: $repo_display"
  if $managed_network; then
    info "Network: $network_name ($(managed_network_summary))"
  else
    info "Network: $network_name ($(custom_network_summary "$network_name"))"
  fi

  build_container_runtime "$container_name" "" "$repos_joined" "$enable_ssh" "$network_name" "$memory" "$cpus" "$pids_limit" "$repo_display" "$network_mode_label"
  # Shell mode has no agent auth volume — add tmpfs so entrypoint can write configs
  docker_cmd+=(--tmpfs "/home/agent/.claude:rw,noexec,nosuid,uid=1000,gid=1000,size=32m")
  docker_cmd+=(--tmpfs "/home/agent/.codex:rw,noexec,nosuid,uid=1000,gid=1000,size=32m")
  docker_cmd+=(-e "GH_CONFIG_DIR=/home/agent/.config/gh")
  if $reuse_gh_auth; then
    if auth_volume_exists "agent-gh-auth"; then
      info "GitHub CLI auth: shared volume reused (agent-gh-auth)"
    else
      info "GitHub CLI auth: shared volume will be created (agent-gh-auth)"
    fi
    append_named_volume "agent-gh-auth" "/home/agent/.config/gh"
    gh_auth_label="shared"
  else
    info "GitHub CLI auth: per-session (ephemeral)"
    gh_auth_label="ephemeral"
  fi
  docker_cmd+=(--label "safe-agentic.gh-auth=$gh_auth_label")

  reset_docker_runtime_state
  docker_label="off"
  if $enable_docker; then
    if $use_docker_socket; then
      info "Docker: VM daemon socket mounted directly (dangerous)"
      append_host_docker_socket_access
      docker_label="host-socket"
    else
      info "Docker: internal daemon sidecar (DinD)"
      append_internal_docker_access "$container_name"
      docker_label="dind"
    fi
  fi
  docker_cmd+=(--label "safe-agentic.docker=$docker_label")
  docker_cmd+=(--label "safe-agentic.auth=none")
  docker_cmd+=("$IMAGE_NAME:$IMAGE_TAG")

  if $dry_run; then
    show_dry_run "$managed_network" "$network_name"
    return 0
  fi

  if [ "$DOCKER_RUNTIME_KIND" = "dind" ]; then
    start_internal_docker_runtime "$container_name" "$network_name"
  fi
  run_container "$managed_network" "$network_name"
}

cmd_list() {
  local json=false

  while [ $# -gt 0 ]; do
    case "$1" in
      --json)
        json=true
        shift
        ;;
      -h|--help)
        cat <<EOF
Usage: agent list [--json]

List all safe-agentic containers.

Options:
  --json   Output raw JSON array (docker ps --format '{{json .}}')
EOF
        return 0
        ;;
      *)
        die "Unknown argument '$1'. Run 'agent help' for usage."
        ;;
    esac
  done

  require_vm
  if $json; then
    vm_exec docker ps -a \
      --filter "name=^${CONTAINER_PREFIX}-" \
      --format '{{json .}}'
  else
    vm_exec docker ps -a \
      --filter "name=^${CONTAINER_PREFIX}-" \
      --format 'table {{.Names}}\t{{.Label "safe-agentic.agent-type"}}\t{{.Label "safe-agentic.repo-display"}}\t{{.Label "safe-agentic.ssh"}}\t{{.Label "safe-agentic.auth"}}\t{{.Label "safe-agentic.gh-auth"}}\t{{.Label "safe-agentic.docker"}}\t{{.Label "safe-agentic.network-mode"}}\t{{.Status}}'
  fi
}

resolve_target_container() {
  local topic="$1"
  local name="$2"
  local latest="$3"
  local resolved=""

  if $latest; then
    resolved=$(resolve_latest_container)
    [ -n "$resolved" ] || die "No running agent containers."
    printf '%s\n' "$resolved"
    return 0
  fi

  [ -n "$name" ] || die_with_help "$topic" "Container name required."
  validate_name_component "$name" "Container name"
  resolved=$(resolve_container_reference "$name" || true)
  [ -n "$resolved" ] || die "No running agent container matches '$name'."
  printf '%s\n' "$resolved"
}

cleanup_copy_artifacts() {
  local remote_tmp="${1:-}"
  local host_tar="${2:-}"
  local host_stage="${3:-}"

  if [ -n "$remote_tmp" ]; then
    vm_exec rm -rf "$remote_tmp" >/dev/null 2>&1 || true
  fi
  if [ -n "$host_tar" ]; then
    rm -f "$host_tar"
  fi
  if [ -n "$host_stage" ]; then
    rm -rf "$host_stage"
  fi
}

move_staged_copy_to_host() {
  local stage_dir="$1"
  local destination="$2"
  local entry=""
  local -a entries=()

  while IFS= read -r -d '' entry; do
    entries+=("$entry")
  done < <(find "$stage_dir" -mindepth 1 -maxdepth 1 -print0)

  if [ "${#entries[@]}" -eq 0 ]; then
    echo "No files were staged for copy." >&2
    return 1
  fi

  if [ "${#entries[@]}" -eq 1 ]; then
    entry="${entries[0]}"

    if [ -d "$destination" ]; then
      mv "$entry" "$destination/"
      return 0
    fi

    if [ -e "$destination" ] && [ -d "$entry" ]; then
      echo "Destination exists and is not a directory: $destination" >&2
      return 1
    fi

    mkdir -p "$(dirname "$destination")"
    mv "$entry" "$destination"
    return 0
  fi

  if [ -e "$destination" ] && [ ! -d "$destination" ]; then
    echo "Destination must be a directory when copying multiple items: $destination" >&2
    return 1
  fi

  mkdir -p "$destination"
  for entry in "${entries[@]}"; do
    mv "$entry" "$destination/"
  done
}

cmd_attach() {
  local topic="attach"
  local name=""
  local latest=false

  while [ $# -gt 0 ]; do
    case "$1" in
      --latest)
        latest=true
        shift
        ;;
      -h|--help)
        cmd_help "$topic"
        return 0
        ;;
      *)
        [ -z "$name" ] || die_with_help "$topic" "Unexpected argument '$1'."
        name="$1"
        shift
        ;;
    esac
  done

  $latest && [ -n "$name" ] && die_with_help "$topic" "Use a name or --latest, not both."

  require_vm
  name=$(resolve_target_container "$topic" "$name" "$latest")
  audit_log "attach" "$name" ""

  # If the container is stopped, restart it; if running, exec into it.
  local state
  local terminal_mode
  state=$(vm_exec docker inspect --format '{{.State.Status}}' "$name" 2>/dev/null || echo "unknown")
  terminal_mode=$(trim_whitespace "$(container_terminal_mode "$name")")
  case "$state" in
    running)
      info "Attaching to running $name..."
      attach_container_console "$name" "$state"
      ;;
    exited|created)
      info "Restarting stopped $name..."
      if [ "$terminal_mode" = "tmux" ]; then
        orb run -m "$VM_NAME" docker start "$name" >/dev/null
        if wait_for_tmux_session "$name"; then
          attach_tmux_session "$name"
        else
          die "Timed out waiting for tmux session in $name after restart."
        fi
      else
        attach_container_console "$name" "$state"
      fi
      ;;
    *)
      die "Container $name is in state '$state' and cannot be attached."
      ;;
  esac
}

cmd_cp() {
  local topic="cp"
  local name=""
  local latest=false
  local container_path=""
  local host_path=""
  local remote_tmp=""
  local host_tar=""
  local host_stage=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --latest)
        latest=true
        shift
        ;;
      -h|--help)
        cmd_help "$topic"
        return 0
        ;;
      *)
        if [ -z "$name" ] && ! $latest; then
          name="$1"
        elif [ -z "$container_path" ]; then
          container_path="$1"
        elif [ -z "$host_path" ]; then
          host_path="$1"
        else
          die_with_help "$topic" "Unexpected argument '$1'."
        fi
        shift
        ;;
    esac
  done

  $latest && [ -n "$name" ] && die_with_help "$topic" "Use a name or --latest, not both."
  [ -n "$container_path" ] || die_with_help "$topic" "Container path required."
  [ -n "$host_path" ] || die_with_help "$topic" "Host path required."

  require_vm
  name=$(resolve_target_container "$topic" "$name" "$latest")

  remote_tmp=$(vm_exec mktemp -d /tmp/safe-agentic-cp.XXXXXX)
  [ -n "$remote_tmp" ] || die "Failed to allocate a VM temp directory."
  host_tar=$(mktemp "${TMPDIR:-/tmp}/safe-agentic-cp.XXXXXX")
  host_stage=$(mktemp -d "${TMPDIR:-/tmp}/safe-agentic-cp.XXXXXX")

  info "Copying $name:$container_path -> $host_path"

  if ! vm_exec docker cp "${name}:${container_path}" "$remote_tmp/" >/dev/null 2>&1; then
    cleanup_copy_artifacts "$remote_tmp" "$host_tar" "$host_stage"
    die "Copy failed: $name:$container_path not found or unreadable."
  fi

  if ! vm_exec tar -C "$remote_tmp" -cf - . > "$host_tar"; then
    cleanup_copy_artifacts "$remote_tmp" "$host_tar" "$host_stage"
    die "Copy failed while streaming data from the VM."
  fi

  if ! tar -xf "$host_tar" -C "$host_stage"; then
    cleanup_copy_artifacts "$remote_tmp" "$host_tar" "$host_stage"
    die "Copy failed while unpacking data on the host."
  fi

  if ! move_staged_copy_to_host "$host_stage" "$host_path"; then
    cleanup_copy_artifacts "$remote_tmp" "$host_tar" "$host_stage"
    die "Copy failed. See error above."
  fi

  cleanup_copy_artifacts "$remote_tmp" "$host_tar" "$host_stage"
  ok "Copied $name:$container_path -> $host_path"
}

cmd_stop() {
  local topic="stop"
  local name=""
  local latest=false
  local stop_all=false

  while [ $# -gt 0 ]; do
    case "$1" in
      --all)
        stop_all=true
        shift
        ;;
      --latest)
        latest=true
        shift
        ;;
      -h|--help)
        cmd_help "$topic"
        return 0
        ;;
      *)
        [ -z "$name" ] || die_with_help "$topic" "Unexpected argument '$1'."
        name="$1"
        shift
        ;;
    esac
  done

  require_vm

  if $stop_all; then
    $latest && die_with_help "$topic" "Use --all or --latest, not both."
    [ -z "$name" ] || die_with_help "$topic" "Use a name or --all, not both."

    info "Stopping all agent containers..."
    local ids names
    ids=$(vm_exec docker ps -a -q --filter "name=^${CONTAINER_PREFIX}-" 2>/dev/null || echo "")
    names=$(vm_exec docker ps -a --format '{{.Names}}' --filter "name=^${CONTAINER_PREFIX}-" 2>/dev/null || echo "")
    if [ -n "$ids" ]; then
      # shellcheck disable=SC2086
      vm_exec docker stop $ids >/dev/null 2>&1 || true
      # shellcheck disable=SC2086
      vm_exec docker rm $ids >/dev/null 2>&1 || true
      while IFS= read -r container_name; do
        [ -n "$container_name" ] || continue
        remove_docker_runtime_for_container "$container_name"
        remove_managed_network "$(network_name_for_container "$container_name")"
      done <<< "$names"
      ok "All agent containers stopped and removed."
    else
      info "No agent containers."
    fi
    return 0
  fi

  $latest && [ -n "$name" ] && die_with_help "$topic" "Use a name or --latest, not both."
  name=$(resolve_target_container "$topic" "$name" "$latest")

  info "Stopping $name..."
  vm_exec docker stop "$name" >/dev/null 2>&1 || true
  vm_exec docker rm "$name" >/dev/null 2>&1 || true
  remove_docker_runtime_for_container "$name"
  remove_managed_network "$(network_name_for_container "$name")"
  audit_log "stop" "$name" ""
  ok "$name stopped and removed."
}

cmd_cleanup() {
  local topic="cleanup"
  local remove_auth=false
  local running stopped managed_networks auth_vols

  while [ $# -gt 0 ]; do
    case "$1" in
      --auth)
        remove_auth=true
        shift
        ;;
      -h|--help)
        cmd_help "$topic"
        return 0
        ;;
      *)
        die_with_help "$topic" "Unknown argument '$1'."
        ;;
    esac
  done

  require_vm
  info "Cleaning up agent containers..."

  running=$(vm_exec docker ps -q --filter "name=^${CONTAINER_PREFIX}-" 2>/dev/null || echo "")
  if [ -n "$running" ]; then
    # shellcheck disable=SC2086
    vm_exec docker stop $running >/dev/null
  fi

  stopped=$(vm_exec docker ps -aq --filter "name=^${CONTAINER_PREFIX}-" 2>/dev/null || echo "")
  if [ -n "$stopped" ]; then
    # shellcheck disable=SC2086
    vm_exec docker rm $stopped >/dev/null
  fi

  cleanup_all_docker_runtimes

  managed_networks=$(vm_exec docker network ls -q \
    --filter "label=app=$IMAGE_NAME" \
    --filter "label=safe-agentic.type=container-network" 2>/dev/null || echo "")
  if [ -n "$managed_networks" ]; then
    # shellcheck disable=SC2086
    vm_exec docker network rm $managed_networks >/dev/null 2>&1 || true
  fi

  if $remove_auth; then
    auth_vols=$(vm_exec docker volume ls -q 2>/dev/null | grep -E '^agent-(claude|codex|gh)-auth$' || echo "")
    if [ -n "$auth_vols" ]; then
      # shellcheck disable=SC2086
      vm_exec docker volume rm $auth_vols >/dev/null 2>&1 || true
    fi
  fi

  vm_exec docker image prune -f --filter "label=app=$IMAGE_NAME" >/dev/null 2>&1 || true
  if $remove_auth; then
    ok "Cleanup complete. Shared auth removed."
  else
    ok "Cleanup complete. Shared auth kept. Run 'agent cleanup --auth' to remove it."
  fi
}

cmd_update() {
  local topic="update"
  local quick=false
  local full=false
  local tarball
  local -a build_args=()

  while [ $# -gt 0 ]; do
    case "$1" in
      --quick)
        quick=true
        shift
        ;;
      --full)
        full=true
        shift
        ;;
      -h|--help)
        cmd_help "$topic"
        return 0
        ;;
      *)
        die_with_help "$topic" "Unknown argument '$1'."
        ;;
    esac
  done

  $quick && $full && die_with_help "$topic" "Use --quick or --full, not both."

  require_cmd orb
  require_cmd git
  require_vm
  ensure_vm_runtime_hardening

  info "[1/3] Preparing tracked build context..."
  tarball=$(mktemp "${TMPDIR:-/tmp}/safe-agentic-ctx.XXXXXX")
  # shellcheck disable=SC2016
  git -C "$REPO_DIR" ls-files -c -z \
    | ( cd "$REPO_DIR" && xargs -0 -I{} sh -c 'if test -e "$1"; then printf "%s\0" "$1"; fi' _ {} ) \
    | COPYFILE_DISABLE=1 tar -C "$REPO_DIR" --null -T - -czf "$tarball"

  info "[2/3] Syncing build context into VM..."
  vm_copy_from_host "$tarball" /tmp/safe-agentic-ctx.tar.gz
  vm_exec bash -c "rm -rf /tmp/safe-agentic && mkdir -p /tmp/safe-agentic && tar -xzf /tmp/safe-agentic-ctx.tar.gz -C /tmp/safe-agentic"
  rm -f "$tarball"
  sync_vm_seccomp_profile

  if $quick; then
    info "[3/3] Building image (quick CLI refresh; streaming logs)..."
    build_args+=(--build-arg "CLI_CACHE_BUST=$(date +%s)")
  elif $full; then
    info "[3/3] Building image (full rebuild; streaming logs)..."
    build_args+=(--no-cache)
  else
    info "[3/3] Building image (streaming logs)..."
  fi

  if [ ${#build_args[@]} -gt 0 ]; then
    vm_exec docker build --progress=plain "${build_args[@]}" -t "$IMAGE_NAME:$IMAGE_TAG" /tmp/safe-agentic/
  else
    vm_exec docker build --progress=plain -t "$IMAGE_NAME:$IMAGE_TAG" /tmp/safe-agentic/
  fi
  ok "Image $IMAGE_NAME:$IMAGE_TAG built successfully."
}

cmd_diagnose() {
  local failures=0
  local ssh_sock=""

  diag_ok()   { echo -e "${GREEN}[ok]${NC} $1"; }
  diag_warn() { echo -e "${YELLOW}[warn]${NC} $1"; }
  diag_fail() { echo -e "${RED}[fail]${NC} $1"; failures=$((failures + 1)); }

  if command -v orb >/dev/null 2>&1; then
    diag_ok "orb installed"
  else
    diag_fail "orb missing. Install OrbStack first."
    return 1
  fi

  if orb list >/dev/null 2>&1; then
    diag_ok "orb reachable"
  else
    diag_fail "orb not responding. Start OrbStack."
    return 1
  fi

  if orb list 2>/dev/null | grep -q "$VM_NAME"; then
    diag_ok "VM '$VM_NAME' exists"
  else
    diag_fail "VM '$VM_NAME' missing. Run 'agent setup'."
    return 1
  fi

  if vm_exec docker info >/dev/null 2>&1; then
    diag_ok "Docker reachable inside VM"
  else
    diag_fail "Docker unavailable inside VM. Re-run 'agent vm start' or 'agent setup'."
  fi

  if verify_vm_runtime_hardening >/dev/null 2>&1; then
    diag_ok "VM hardening verified"
  else
    diag_fail "VM hardening drift detected. Run 'agent vm start'."
  fi

  if vm_exec docker image inspect "$IMAGE_NAME:$IMAGE_TAG" >/dev/null 2>&1; then
    diag_ok "Image '$IMAGE_NAME:$IMAGE_TAG' present"
  else
    diag_fail "Image '$IMAGE_NAME:$IMAGE_TAG' missing. Run 'agent update'."
  fi

  if vm_exec bash -c 'test -S /var/run/docker.sock'; then
    diag_ok "VM Docker socket visible: /var/run/docker.sock"
  else
    diag_fail "VM Docker socket missing at /var/run/docker.sock."
  fi

  # shellcheck disable=SC2016
  ssh_sock=$(vm_exec bash -c 'echo "${SSH_AUTH_SOCK:-}"' 2>/dev/null || true)
  if [ -n "$ssh_sock" ]; then
    diag_ok "VM SSH agent socket visible: $ssh_sock"
  else
    diag_warn "No VM SSH agent socket. Private git@ repos need 1Password SSH agent + --ssh."
  fi

  if [ -f "$DEFAULTS_FILE" ]; then
    diag_ok "Defaults file loaded: $DEFAULTS_FILE"
  else
    diag_warn "No defaults file at $DEFAULTS_FILE"
  fi

  [ "$failures" -eq 0 ]
}

cmd_vm() {
  local topic="vm"
  local subcmd="${1:-}"

  case "$subcmd" in
    ssh)
      orb ssh "$VM_NAME"
      ;;
    stop)
      info "Stopping VM..."
      orb stop "$VM_NAME"
      ok "VM stopped."
      ;;
    start)
      info "Starting VM..."
      orb start "$VM_NAME"
      info "Re-applying VM hardening..."
      reapply_vm_runtime_hardening
      ok "VM started and hardened."
      ;;
    -h|--help)
      cmd_help "$topic"
      ;;
    "")
      die_with_help "$topic" "Subcommand required."
      ;;
    *)
      die_with_help "$topic" "Unknown subcommand '$subcmd'."
      ;;
  esac
}

print_help_summary() {
  cat <<EOF
Usage: agent summary <name>|--latest

Show a one-screen overview of a container, including:
  - Name, type, status, uptime/exit time
  - Repo
  - Flags (SSH, auth, Docker)
  - Git status: branch, commits since clone, files changed
  - Cost estimate
  - Todo status

Options:
  --latest    Target the most recently started container
  -h, --help

Examples:
  agent summary my-task
  agent summary --latest
EOF
}

cmd_summary() {
  local topic="summary"
  local name=""
  local latest=false

  while [ $# -gt 0 ]; do
    case "$1" in
      --latest)
        latest=true
        shift
        ;;
      -h|--help)
        print_help_summary
        return 0
        ;;
      *)
        [ -z "$name" ] || die_with_help "$topic" "Unexpected argument '$1'."
        name="$1"
        shift
        ;;
    esac
  done

  $latest && [ -n "$name" ] && die_with_help "$topic" "Use a name or --latest, not both."

  if ! $latest && [ -z "$name" ]; then
    die_with_help "$topic" "Container name or --latest required."
  fi

  require_vm
  name=$(resolve_target_container "$topic" "$name" "$latest")

  # Gather basic container info
  local state started_at finished_at agent_type repo_display ssh_label auth_label docker_label
  state=$(vm_exec docker inspect --format '{{.State.Status}}' "$name" 2>/dev/null || echo "unknown")
  started_at=$(vm_exec docker inspect --format '{{.State.StartedAt}}' "$name" 2>/dev/null || echo "")
  finished_at=$(vm_exec docker inspect --format '{{.State.FinishedAt}}' "$name" 2>/dev/null || echo "")
  agent_type=$(vm_exec docker inspect --format '{{index .Config.Labels "safe-agentic.agent-type"}}' "$name" 2>/dev/null || echo "")
  repo_display=$(vm_exec docker inspect --format '{{index .Config.Labels "safe-agentic.repo-display"}}' "$name" 2>/dev/null || echo "-")
  ssh_label=$(vm_exec docker inspect --format '{{index .Config.Labels "safe-agentic.ssh"}}' "$name" 2>/dev/null || echo "")
  auth_label=$(vm_exec docker inspect --format '{{index .Config.Labels "safe-agentic.auth"}}' "$name" 2>/dev/null || echo "")
  docker_label=$(vm_exec docker inspect --format '{{index .Config.Labels "safe-agentic.docker"}}' "$name" 2>/dev/null || echo "")

  echo ""
  echo -e "${CYAN}=== Agent Summary: $name ===${NC}"
  echo ""
  echo -e "  ${GREEN}Type:${NC}     ${agent_type:-unknown}"
  echo -e "  ${GREEN}Status:${NC}   $state"
  if [ "$state" = "running" ]; then
    echo -e "  ${GREEN}Started:${NC}  $started_at"
  else
    echo -e "  ${GREEN}Started:${NC}  $started_at"
    echo -e "  ${GREEN}Exited:${NC}   $finished_at"
  fi
  echo -e "  ${GREEN}Repo:${NC}     $repo_display"
  echo ""
  echo -e "  ${GREEN}SSH:${NC}      ${ssh_label:-off}"
  echo -e "  ${GREEN}Auth:${NC}     ${auth_label:-ephemeral}"
  echo -e "  ${GREEN}Docker:${NC}   ${docker_label:-off}"
  echo ""

  # Git status (only if running)
  if [ "$state" = "running" ]; then
    echo -e "  ${GREEN}Git status:${NC}"
    local branch commits_since changed_files
    # shellcheck disable=SC2016
    branch=$(vm_exec docker exec "$name" bash -c 'cd "$(find /workspace -mindepth 1 -maxdepth 1 -type d | head -1)" 2>/dev/null || cd /workspace; git rev-parse --abbrev-ref HEAD 2>/dev/null' 2>/dev/null | tr -d '[:space:]' || echo "")
    # shellcheck disable=SC2016
    commits_since=$(vm_exec docker exec "$name" bash -c 'cd "$(find /workspace -mindepth 1 -maxdepth 1 -type d | head -1)" 2>/dev/null || cd /workspace; git rev-list --count HEAD 2>/dev/null || echo 0' 2>/dev/null | tr -d '[:space:]' || echo "?")
    # shellcheck disable=SC2016
    changed_files=$(vm_exec docker exec "$name" bash -c 'cd "$(find /workspace -mindepth 1 -maxdepth 1 -type d | head -1)" 2>/dev/null || cd /workspace; git diff --name-only 2>/dev/null | wc -l' 2>/dev/null | tr -d '[:space:]' || echo "?")
    echo -e "    Branch:          ${branch:-unknown}"
    echo -e "    Commits:         ${commits_since:-?}"
    echo -e "    Files changed:   ${changed_files:-?}"
    echo ""

    # Todo status
    local todos_summary
    todos_summary=$(vm_exec docker exec "$name" python3 -c '
import json, os, sys
path = "/workspace/.safe-agentic/todos.json"
if not os.path.exists(path):
    print("No todos")
    sys.exit(0)
try:
    with open(path) as f:
        todos = json.load(f)
except Exception:
    print("No todos")
    sys.exit(0)
done = sum(1 for t in todos if t.get("done"))
total = len(todos)
print("{}/{} complete".format(done, total))
' 2>/dev/null || echo "")
    echo -e "  ${GREEN}Todos:${NC}    ${todos_summary:-No todos}"
    echo ""

    # Cost estimate
    local config_dir jsonl_data
    case "$agent_type" in
      codex) config_dir="/home/agent/.codex" ;;
      *) config_dir="/home/agent/.claude" ;;
    esac

    jsonl_data=$(vm_exec docker exec "$name" bash -c "
      find '${config_dir}/sessions' -name '*.jsonl' 2>/dev/null | while read -r f; do cat \"\$f\"; done
      [ -f '${config_dir}/history.jsonl' ] && cat '${config_dir}/history.jsonl' || true
    " 2>/dev/null || true)

    if [ -n "$jsonl_data" ]; then
      echo -e "  ${GREEN}Cost estimate:${NC}"
      local py_script
      py_script=$(mktemp /tmp/agent-cost-XXXXXX.py)
      trap 'rm -f "$py_script"' RETURN
      cat >"$py_script" <<'PYEOF'
import sys, json, re
PRICES = {
    "claude-opus-4-6":   (15.0, 75.0),
    "claude-sonnet-4-6": (3.0,  15.0),
    "claude-haiku-4-5":  (0.80,  4.0),
}
DEFAULT_PRICE = (3.0, 15.0)
totals_by_model = {}
for line in sys.stdin:
    line = line.strip()
    if not line:
        continue
    try:
        obj = json.loads(line)
    except json.JSONDecodeError:
        continue
    usage = obj.get("usage") or (obj.get("payload") or {}).get("usage")
    if not usage or not isinstance(usage, dict):
        continue
    model = (obj.get("model") or (obj.get("payload") or {}).get("model") or "unknown")
    model_key = re.sub(r"-\d{8}$", "", model)
    inp = int(usage.get("input_tokens", 0))
    out = int(usage.get("output_tokens", 0))
    if model_key not in totals_by_model:
        totals_by_model[model_key] = [0, 0]
    totals_by_model[model_key][0] += inp
    totals_by_model[model_key][1] += out
if not totals_by_model:
    print("    No token data yet.")
    sys.exit(0)
grand_in = grand_out = grand_cost = 0.0
for model_key in sorted(totals_by_model):
    inp, out = totals_by_model[model_key]
    price_in, price_out = PRICES.get(model_key, DEFAULT_PRICE)
    cost = (inp / 1_000_000) * price_in + (out / 1_000_000) * price_out
    grand_in += inp
    grand_out += out
    grand_cost += cost
print(f"    ~${grand_cost:.4f}  ({int(grand_in):,} in / {int(grand_out):,} out tokens)")
PYEOF
      echo "$jsonl_data" | python3 "$py_script"
      echo ""
    fi
  fi
}

print_help_config() {
  cat <<EOF
Usage: agent config <show|set|get|reset>

Manage default settings stored in ${DEFAULTS_FILE}.

Subcommands:
  show                    Print current defaults (or "No defaults set")
  set <key> <value>       Set a default value (creates file if needed)
  get <key>               Show a specific default value
  reset                   Delete the defaults file

Valid keys:
  memory          SAFE_AGENTIC_DEFAULT_MEMORY
  cpus            SAFE_AGENTIC_DEFAULT_CPUS
  pids-limit      SAFE_AGENTIC_DEFAULT_PIDS_LIMIT
  ssh             SAFE_AGENTIC_DEFAULT_SSH
  reuse-auth      SAFE_AGENTIC_DEFAULT_REUSE_AUTH
  reuse-gh-auth   SAFE_AGENTIC_DEFAULT_REUSE_GH_AUTH
  docker          SAFE_AGENTIC_DEFAULT_DOCKER
  network         SAFE_AGENTIC_DEFAULT_NETWORK
  identity        SAFE_AGENTIC_DEFAULT_IDENTITY

Examples:
  agent config show
  agent config set memory 16g
  agent config set ssh true
  agent config get memory
  agent config reset
EOF
}

# Map friendly key names to env var names used in the defaults file.
_config_key_to_env() {
  case "$1" in
    memory)       echo "SAFE_AGENTIC_DEFAULT_MEMORY" ;;
    cpus)         echo "SAFE_AGENTIC_DEFAULT_CPUS" ;;
    pids-limit)   echo "SAFE_AGENTIC_DEFAULT_PIDS_LIMIT" ;;
    ssh)          echo "SAFE_AGENTIC_DEFAULT_SSH" ;;
    reuse-auth)   echo "SAFE_AGENTIC_DEFAULT_REUSE_AUTH" ;;
    reuse-gh-auth) echo "SAFE_AGENTIC_DEFAULT_REUSE_GH_AUTH" ;;
    docker)       echo "SAFE_AGENTIC_DEFAULT_DOCKER" ;;
    network)      echo "SAFE_AGENTIC_DEFAULT_NETWORK" ;;
    identity)     echo "SAFE_AGENTIC_DEFAULT_IDENTITY" ;;
    *) return 1 ;;
  esac
}

cmd_config() {
  local topic="config"
  local subcmd="${1:-}"

  case "$subcmd" in
    -h|--help)
      print_help_config
      return 0
      ;;
    show|set|get|reset)
      shift
      ;;
    "")
      die_with_help "$topic" "Subcommand required (show|set|get|reset)."
      ;;
    *)
      die_with_help "$topic" "Unknown subcommand '$subcmd'. Use show, set, get, or reset."
      ;;
  esac

  case "$subcmd" in
    show)
      if [ ! -f "$DEFAULTS_FILE" ]; then
        echo "No defaults set."
        return 0
      fi
      cat "$DEFAULTS_FILE"
      ;;
    set)
      local key="${1:-}"
      local value="${2:-}"
      [ -n "$key" ] || die_with_help "$topic" "Key required."
      [ -n "$value" ] || die_with_help "$topic" "Value required."
      local env_key
      env_key=$(_config_key_to_env "$key") || die "Unknown config key '$key'. Run 'agent config --help' for valid keys."
      mkdir -p "$(dirname "$DEFAULTS_FILE")"
      # Remove existing line for this key, then append new value.
      if [ -f "$DEFAULTS_FILE" ]; then
        local tmpfile
        tmpfile=$(mktemp "${TMPDIR:-/tmp}/safe-agentic-config.XXXXXX")
        grep -v "^${env_key}=" "$DEFAULTS_FILE" > "$tmpfile" || true
        mv "$tmpfile" "$DEFAULTS_FILE"
      fi
      printf '%s=%s\n' "$env_key" "$value" >> "$DEFAULTS_FILE"
      ok "Set $key=$value in $DEFAULTS_FILE"
      ;;
    get)
      local key="${1:-}"
      [ -n "$key" ] || die_with_help "$topic" "Key required."
      local env_key
      env_key=$(_config_key_to_env "$key") || die "Unknown config key '$key'. Run 'agent config --help' for valid keys."
      if [ ! -f "$DEFAULTS_FILE" ]; then
        echo "No defaults set."
        return 0
      fi
      local val
      val=$(grep "^${env_key}=" "$DEFAULTS_FILE" | tail -1 | cut -d= -f2-) || true
      if [ -n "$val" ]; then
        echo "$val"
      else
        echo "(not set)"
      fi
      ;;
    reset)
      if [ -f "$DEFAULTS_FILE" ]; then
        rm -f "$DEFAULTS_FILE"
        ok "Defaults file removed: $DEFAULTS_FILE"
      else
        echo "No defaults file to remove."
      fi
      ;;
  esac
}

cmd_help() {
  local topic="${1:-}"

  case "$topic" in
    ""|help)
      print_help_general
      ;;
    spawn)
      print_help_spawn
      ;;
    shell)
      print_help_shell
      ;;
    attach)
      print_help_attach
      ;;
    cp)
      print_help_cp
      ;;
    peek)
      print_help_peek
      ;;
    diff)
      print_help_diff
      ;;
    checkpoint)
      print_help_checkpoint
      ;;
    todo)
      print_help_todo
      ;;
    stop)
      print_help_stop
      ;;
    cleanup)
      print_help_cleanup
      ;;
    update)
      print_help_update
      ;;
    vm)
      print_help_vm
      ;;
    diagnose)
      print_help_diagnose
      ;;
    review)
      print_help_review
      ;;
    audit)
      print_help_audit
      ;;
    cost)
      print_help_cost
      ;;
    fleet)
      print_help_fleet
      ;;
    pipeline)
      print_help_pipeline
      ;;
    pr)
      print_help_pr
      ;;
    config)
      print_help_config
      ;;
    summary)
      print_help_summary
      ;;
    *)
      # Search all help text for the keyword
      local keyword="$topic"
      local combined_help
      combined_help=$(
        print_help_general
        print_help_spawn
        print_help_shell
        print_help_attach
        print_help_cp
        print_help_peek
        print_help_diff
        print_help_checkpoint
        print_help_todo
        print_help_stop
        print_help_cleanup
        print_help_update
        print_help_vm
        print_help_diagnose
        print_help_review
        print_help_audit
        print_help_cost
        print_help_fleet
        print_help_pipeline
        print_help_pr
        print_help_config
        print_help_summary
      ) 2>/dev/null
      local matches
      matches=$(printf '%s\n' "$combined_help" | grep -i --color=auto -C 2 "$keyword" 2>/dev/null) || true
      if [ -n "$matches" ]; then
        printf '%s\n' "$matches"
      else
        die "No help found for '$keyword'."
      fi
      ;;
  esac
}

cmd_mcp_login() {
  local topic="mcp-login"
  local name=""
  local latest=false
  local mcp_server=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --latest)
        latest=true
        shift
        ;;
      -h|--help)
        cat <<EOF
Usage: agent mcp-login [container] <mcp-server>
       agent mcp-login --latest <mcp-server>

Authenticate an MCP server via OAuth. Runs in a temporary container
with the shared auth volume so the token persists for all agents.

Container name is optional — without it, uses the default
agent-codex-auth volume. One-time setup per MCP server.

Example:
  agent mcp-login linear
  agent mcp-login cardinality-restrictions linear
  agent mcp-login --latest notion
EOF
        return 0
        ;;
      *)
        # Collect positional args; we figure out which is which after parsing
        if [ -z "$name" ]; then
          name="$1"
        elif [ -z "$mcp_server" ]; then
          mcp_server="$1"
        else
          die_with_help "$topic" "Unexpected argument '$1'."
        fi
        shift
        ;;
    esac
  done

  # With one positional arg: it's the MCP server name (no container).
  # With two: first is container, second is MCP server.
  if [ -z "$mcp_server" ]; then
    mcp_server="$name"
    name=""
  fi
  [ -n "$mcp_server" ] || die "MCP server name required. Example: agent mcp-login linear"

  require_vm

  # Determine the auth volume. If a container name is given, read it from
  # the container. Otherwise use the default shared codex auth volume.
  local auth_volume=""
  if [ -n "$name" ] || $latest; then
    name=$(resolve_target_container "$topic" "$name" "$latest")
    auth_volume=$(vm_exec docker inspect --format \
      '{{range .Mounts}}{{if eq .Destination "/home/agent/.codex"}}{{.Name}}{{end}}{{end}}' \
      "$name" 2>/dev/null || echo "")
    [ -n "$auth_volume" ] || die "Container $name has no codex auth volume. Use --reuse-auth when spawning."
  else
    auth_volume="agent-codex-auth"
    # Create the volume if it doesn't exist yet
    vm_exec docker volume inspect "$auth_volume" >/dev/null 2>&1 \
      || vm_exec docker volume create "$auth_volume" >/dev/null
  fi

  info "Running MCP OAuth login for '$mcp_server'..."
  info "A URL will appear — open it in your browser."

  # Run login in a temporary container that bypasses userns-remap so we can
  # use --network=host (userns-remap blocks host networking).
  # --userns=host overrides the daemon-level remap for this container only.
  # The OAuth callback server binds to VM localhost; OrbStack auto-forwards
  # to macOS. Auth volume is shared so the token persists.
  # --user root: the auth volume was created under userns-remap (uid 101000),
  # but --userns=host maps uid 1000 to real 1000 which can't read those files.
  # Root can access them regardless. This is safe — it's an ephemeral container.
  orb run -m "$VM_NAME" docker run --rm -it \
    --userns=host \
    --network=host \
    --user root \
    --entrypoint codex \
    -e "CODEX_HOME=/home/agent/.codex" \
    -v "$auth_volume:/home/agent/.codex" \
    "$IMAGE_NAME:$IMAGE_TAG" \
    mcp login "$mcp_server"
  local login_status=$?

  if [ "$login_status" -eq 0 ]; then
    # Fix ownership: the login container ran with --userns=host (real root),
    # so files are owned by uid 0. The main agent container uses userns-remap
    # where uid 1000 maps to VM uid 101000. Chown from the VM so the main
    # container can read the files.
    local vol_path
    vol_path=$(vm_exec docker volume inspect --format '{{.Mountpoint}}' "$auth_volume" 2>/dev/null || echo "")
    if [ -n "$vol_path" ]; then
      vm_exec sudo chown -R 101000:101000 "$vol_path" 2>/dev/null || true
    fi
    ok "MCP '$mcp_server' authenticated. Token stored in auth volume '$auth_volume'."
  else
    warn "MCP login exited with status $login_status."
  fi
}

cmd_sessions() {
  local topic="sessions"
  local name=""
  local latest=false
  local dest=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --latest)
        latest=true
        shift
        ;;
      -h|--help)
        cat <<EOF
Usage: agent sessions <container> [destination]
       agent sessions --latest [destination]

Export agent session history from a container to the host.
Copies session files, history, and session index.
Default destination: ./agent-sessions/<container-name>/

Example:
  agent sessions cardinality-restrictions
  agent sessions --latest ~/codex-sessions/
EOF
        return 0
        ;;
      *)
        if [ -z "$name" ] && ! $latest; then
          name="$1"
        elif [ -z "$dest" ]; then
          dest="$1"
        else
          die_with_help "$topic" "Unexpected argument '$1'."
        fi
        shift
        ;;
    esac
  done

  require_vm
  name=$(resolve_target_container "$topic" "$name" "$latest")
  [ -z "$dest" ] && dest="./agent-sessions/$name"

  # Ensure container is accessible
  local state
  state=$(vm_exec docker inspect --format '{{.State.Status}}' "$name" 2>/dev/null || echo "unknown")
  if [ "$state" != "running" ]; then
    info "Starting container $name..."
    vm_exec docker start "$name" >/dev/null 2>&1
    sleep 1
  fi

  # Detect agent type
  local agent_type config_dir
  agent_type=$(vm_exec docker inspect --format '{{index .Config.Labels "safe-agentic.agent-type"}}' "$name" 2>/dev/null || echo "")
  case "$agent_type" in
    codex) config_dir="/home/agent/.codex" ;;
    claude) config_dir="/home/agent/.claude" ;;
    *) config_dir="/home/agent/.codex" ;;  # default to codex
  esac

  mkdir -p "$dest"

  info "Exporting sessions from $name ($agent_type)..."

  # Extract session-related files from the container
  local tmptar
  tmptar=$(mktemp /tmp/agent-sessions-XXXXXX.tar)
  trap 'rm -f "$tmptar"' RETURN

  orb run -m "$VM_NAME" docker exec -i "$name" \
    tar -cf - -C "$config_dir" \
      --ignore-failed-read \
      sessions/ \
      history.jsonl \
      session_index.jsonl \
      archived_sessions/ \
      2>/dev/null > "$tmptar"

  if [ ! -s "$tmptar" ]; then
    warn "No session data found in $name."
    return 0
  fi

  tar -xf "$tmptar" -C "$dest" 2>/dev/null

  local count
  count=$(find "$dest" -type f 2>/dev/null | wc -l | tr -d ' ')
  ok "Exported $count files to $dest"
}

cmd_peek() {
  local topic="peek"
  local name=""
  local latest=false
  local lines=30

  while [ $# -gt 0 ]; do
    case "$1" in
      --latest)
        latest=true
        shift
        ;;
      --lines)
        require_option_value "$topic" "--lines" "${2:-}"
        lines="$2"
        shift 2
        ;;
      -h|--help)
        print_help_peek
        return 0
        ;;
      *)
        [ -z "$name" ] || die_with_help "$topic" "Unexpected argument '$1'."
        name="$1"
        shift
        ;;
    esac
  done

  $latest && [ -n "$name" ] && die "Use a name or --latest, not both."

  require_vm
  name=$(resolve_target_container "$topic" "$name" "$latest")

  local state
  state=$(vm_exec docker inspect --format '{{.State.Status}}' "$name" 2>/dev/null || echo "unknown")
  [ "$state" = "running" ] || die "Container $name is not running (state: $state)."

  local terminal_mode
  terminal_mode=$(trim_whitespace "$(vm_exec docker inspect --format '{{index .Config.Labels "safe-agentic.terminal"}}' "$name" 2>/dev/null || echo "")")
  [ "$terminal_mode" = "tmux" ] || die "No tmux session in $name."

  vm_exec docker exec "$name" tmux capture-pane -t "${SAFE_AGENTIC_TMUX_SESSION_NAME:-safe-agentic}" -p -S "-${lines}"
}

cmd_diff() {
  local topic="diff"
  local name=""
  local latest=false
  local stat=false

  while [ $# -gt 0 ]; do
    case "$1" in
      --latest)
        latest=true
        shift
        ;;
      --stat)
        stat=true
        shift
        ;;
      -h|--help)
        print_help_diff
        return 0
        ;;
      *)
        [ -z "$name" ] || die_with_help "$topic" "Unexpected argument '$1'."
        name="$1"
        shift
        ;;
    esac
  done

  $latest && [ -n "$name" ] && die "Use a name or --latest, not both."

  if ! $latest && [ -z "$name" ]; then
    die_with_help "$topic" "Container name or --latest required."
  fi

  require_vm
  name=$(resolve_target_container "$topic" "$name" "$latest")

  local state
  state=$(vm_exec docker inspect --format '{{.State.Status}}' "$name" 2>/dev/null || echo "unknown")
  [ "$state" = "running" ] || die "Container $name is not running (state: $state)."

  # shellcheck disable=SC2016
  if $stat; then
    vm_exec docker exec "$name" bash -c 'cd "$(find /workspace -mindepth 1 -maxdepth 1 -type d | head -1)" 2>/dev/null || cd /workspace; git diff --stat'
  else
    vm_exec docker exec "$name" bash -c 'cd "$(find /workspace -mindepth 1 -maxdepth 1 -type d | head -1)" 2>/dev/null || cd /workspace; git diff'
  fi
}

cmd_checkpoint() {
  local topic="checkpoint"
  local subcmd="${1:-}"

  case "$subcmd" in
    -h|--help)
      print_help_checkpoint
      return 0
      ;;
    create|list|revert)
      shift
      ;;
    "")
      die_with_help "$topic" "Subcommand required (create|list|revert)."
      ;;
    *)
      die_with_help "$topic" "Unknown subcommand '$subcmd'. Use create, list, or revert."
      ;;
  esac

  local name=""
  local latest=false
  local label=""
  local ref=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --latest)
        latest=true
        shift
        ;;
      -h|--help)
        print_help_checkpoint
        return 0
        ;;
      *)
        if [ "$subcmd" = "revert" ]; then
          if [ -z "$name" ] && ! $latest; then
            name="$1"
          elif [ -z "$ref" ]; then
            ref="$1"
          else
            die_with_help "$topic" "Unexpected argument '$1'."
          fi
        else
          if [ -z "$name" ] && ! $latest; then
            name="$1"
          elif [ -z "$label" ]; then
            label="$1"
          else
            die_with_help "$topic" "Unexpected argument '$1'."
          fi
        fi
        shift
        ;;
    esac
  done

  $latest && [ -n "$name" ] && die "Use a name or --latest, not both."

  if ! $latest && [ -z "$name" ]; then
    die_with_help "$topic" "Container name or --latest required."
  fi

  if [ "$subcmd" = "revert" ] && [ -z "$ref" ]; then
    die_with_help "$topic" "Checkpoint ref required for revert."
  fi

  require_vm
  name=$(resolve_target_container "$topic" "$name" "$latest")

  local state
  state=$(vm_exec docker inspect --format '{{.State.Status}}' "$name" 2>/dev/null || echo "unknown")
  [ "$state" = "running" ] || die "Container $name is not running (state: $state)."

  # shellcheck disable=SC2016
  case "$subcmd" in
    create)
      [ -z "$label" ] && label="checkpoint-$(date +%s)"
      validate_name_component "$label" "Checkpoint label"
      local stash_sha
      stash_sha=$(vm_exec docker exec "$name" bash -c \
        'cd "$(find /workspace -mindepth 1 -maxdepth 1 -type d | head -1)" 2>/dev/null || cd /workspace; git add -A && git stash create' 2>/dev/null || true)
      stash_sha=$(echo "$stash_sha" | tr -d '[:space:]')
      if [ -z "$stash_sha" ]; then
        info "No changes to checkpoint."
        return 0
      fi
      vm_exec docker exec -e SA_LABEL="$label" -e SA_SHA="$stash_sha" "$name" bash -c \
        'cd "$(find /workspace -mindepth 1 -maxdepth 1 -type d | head -1)" 2>/dev/null || cd /workspace; git update-ref "refs/safe-agentic/checkpoints/$SA_LABEL" "$SA_SHA"'
      ok "Checkpoint '$label' created ($stash_sha) in $name."
      ;;
    list)
      vm_exec docker exec "$name" bash -c \
        'cd "$(find /workspace -mindepth 1 -maxdepth 1 -type d | head -1)" 2>/dev/null || cd /workspace; git for-each-ref --format="%(objectname:short) %(creatordate:unix) %(refname:lstrip=3)" refs/safe-agentic/checkpoints/' \
        | while IFS= read -r line; do
            local sha epoch lbl
            sha=$(echo "$line" | awk '{print $1}')
            epoch=$(echo "$line" | awk '{print $2}')
            lbl=$(echo "$line" | awk '{$1=$2=""; print}' | sed 's/^ *//')
            if [ -n "$epoch" ] && [ "$epoch" -gt 0 ] 2>/dev/null; then
              ts=$(date -r "$epoch" '+%Y-%m-%d %H:%M:%S' 2>/dev/null || date -d "@$epoch" '+%Y-%m-%d %H:%M:%S' 2>/dev/null || echo "$epoch")
            else
              ts="$epoch"
            fi
            printf '%s  %s  %s\n' "$sha" "$ts" "$lbl"
          done
      ;;
    revert)
      validate_name_component "$ref" "Checkpoint ref"
      vm_exec docker exec -e SA_REF="$ref" "$name" bash -c \
        'cd "$(find /workspace -mindepth 1 -maxdepth 1 -type d | head -1)" 2>/dev/null || cd /workspace; git checkout . && git clean -fd && git stash apply "refs/safe-agentic/checkpoints/$SA_REF"'
      ok "Reverted $name to checkpoint '$ref'."
      ;;
  esac
}

cmd_todo() {
  local topic="todo"
  local subcmd="${1:-}"

  case "$subcmd" in
    -h|--help)
      print_help_todo
      return 0
      ;;
    add|list|check|uncheck)
      shift
      ;;
    "")
      die_with_help "$topic" "Subcommand required (add|list|check|uncheck)."
      ;;
    *)
      die_with_help "$topic" "Unknown subcommand '$subcmd'. Use add, list, check, or uncheck."
      ;;
  esac

  local name=""
  local latest=false
  local text=""
  local index=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --latest)
        latest=true
        shift
        ;;
      -h|--help)
        print_help_todo
        return 0
        ;;
      *)
        if [ -z "$name" ] && ! $latest; then
          name="$1"
        elif [ "$subcmd" = "add" ]; then
          if [ -z "$text" ]; then
            text="$1"
          else
            text="$text $1"
          fi
        elif [ "$subcmd" = "check" ] || [ "$subcmd" = "uncheck" ]; then
          [ -z "$index" ] || die_with_help "$topic" "Unexpected argument '$1'."
          index="$1"
        else
          die_with_help "$topic" "Unexpected argument '$1'."
        fi
        shift
        ;;
    esac
  done

  $latest && [ -n "$name" ] && die "Use a name or --latest, not both."

  if ! $latest && [ -z "$name" ]; then
    die_with_help "$topic" "Container name or --latest required."
  fi

  if [ "$subcmd" = "add" ] && [ -z "$text" ]; then
    die_with_help "$topic" "Todo text required for add."
  fi

  if { [ "$subcmd" = "check" ] || [ "$subcmd" = "uncheck" ]; } && [ -z "$index" ]; then
    die_with_help "$topic" "Index required for $subcmd."
  fi

  require_vm
  name=$(resolve_target_container "$topic" "$name" "$latest")

  local state
  state=$(vm_exec docker inspect --format '{{.State.Status}}' "$name" 2>/dev/null || echo "unknown")
  [ "$state" = "running" ] || die "Container $name is not running (state: $state)."

  local todos_file="/workspace/.safe-agentic/todos.json"

  case "$subcmd" in
    add)
      # Ensure directory exists
      vm_exec docker exec "$name" mkdir -p /workspace/.safe-agentic
      # JSON-encode the text on the host to pass safely into the container
      local escaped_text
      escaped_text=$(python3 -c 'import sys,json; print(json.dumps(sys.stdin.read()))' <<< "$text")
      # Pipe python script via stdin to avoid quoting issues with multiline -c
      vm_exec docker exec -i "$name" python3 - \
        "$todos_file" "$escaped_text" <<'PYEOF'
import json, os, sys
path = sys.argv[1]
text_json = sys.argv[2]
text = json.loads(text_json)
todos = []
if os.path.exists(path):
    try:
        with open(path) as f:
            todos = json.load(f)
    except Exception:
        todos = []
todos.append({'text': text, 'done': False})
with open(path, 'w') as f:
    json.dump(todos, f, indent=2)
print('Added todo #{}: {}'.format(len(todos), text))
PYEOF
      ;;
    list)
      # Pipe python script via stdin to avoid quoting issues
      vm_exec docker exec -i "$name" python3 - "$todos_file" <<'PYEOF'
import json, os, sys
path = sys.argv[1]
if not os.path.exists(path):
    print('No todos yet.')
    sys.exit(0)
try:
    with open(path) as f:
        todos = json.load(f)
except Exception:
    print('No todos yet.')
    sys.exit(0)
if not todos:
    print('No todos yet.')
    sys.exit(0)
done_count = sum(1 for t in todos if t.get('done'))
for i, t in enumerate(todos, 1):
    mark = 'x' if t.get('done') else ' '
    print('[{}] {}. {}'.format(mark, i, t.get('text', '')))
print('')
print('{}/{} complete'.format(done_count, len(todos)))
PYEOF
      ;;
    check|uncheck)
      local done_flag
      [ "$subcmd" = "check" ] && done_flag="1" || done_flag="0"
      # Pipe python script via stdin to avoid quoting issues
      vm_exec docker exec -i "$name" python3 - \
        "$todos_file" "$index" "$done_flag" <<'PYEOF'
import json, os, sys
path = sys.argv[1]
idx = int(sys.argv[2]) - 1
done = sys.argv[3] == '1'
if not os.path.exists(path):
    print('No todos found.', file=sys.stderr)
    sys.exit(1)
with open(path) as f:
    todos = json.load(f)
if idx < 0 or idx >= len(todos):
    print('Index {} out of range (1-{}).'.format(idx + 1, len(todos)), file=sys.stderr)
    sys.exit(1)
todos[idx]['done'] = done
with open(path, 'w') as f:
    json.dump(todos, f, indent=2)
label = 'done' if done else 'not done'
print('Todo #{} marked as {}.'.format(idx + 1, label))
PYEOF
      ;;
  esac
}

cmd_review() {
  local topic="review"
  local name=""
  local latest=false
  local base=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --latest)
        latest=true
        shift
        ;;
      --base)
        require_option_value "$topic" "--base" "${2:-}"
        base="$2"
        shift 2
        ;;
      -h|--help)
        print_help_review
        return 0
        ;;
      *)
        [ -z "$name" ] || die_with_help "$topic" "Unexpected argument '$1'."
        name="$1"
        shift
        ;;
    esac
  done

  $latest && [ -n "$name" ] && die "Use a name or --latest, not both."

  require_vm
  name=$(resolve_target_container "$topic" "$name" "$latest")

  local state
  state=$(vm_exec docker inspect --format '{{.State.Status}}' "$name" 2>/dev/null || echo "unknown")
  [ "$state" = "running" ] || die "Container $name is not running (state: $state)."

  # Detect workspace directory inside container
  # shellcheck disable=SC2016
  local workspace_cd='cd "$(find /workspace -mindepth 1 -maxdepth 1 -type d | head -1)" 2>/dev/null || cd /workspace'

  # Check if codex is available in the container
  if vm_exec docker exec "$name" command -v codex >/dev/null 2>&1; then
    if [ -n "$base" ]; then
      info "Running codex review --base $base in $name..."
      vm_exec docker exec -e SA_BASE="$base" "$name" bash -lc "$workspace_cd && codex review --base \"\$SA_BASE\""
    else
      info "Running codex review --uncommitted in $name..."
      vm_exec docker exec "$name" bash -lc "$workspace_cd && codex review --uncommitted"
    fi
  else
    if [ -n "$base" ]; then
      info "Running git diff against $base in $name (codex not available)..."
      vm_exec docker exec -e SA_BASE="$base" "$name" bash -lc "$workspace_cd && git diff \"\$SA_BASE\""
    else
      info "Running git diff in $name (codex not available)..."
      vm_exec docker exec "$name" bash -lc "$workspace_cd && git diff"
    fi
  fi
}

cmd_audit() {
  local topic="audit"
  local lines=50

  while [ $# -gt 0 ]; do
    case "$1" in
      --lines)
        require_option_value "$topic" "--lines" "${2:-}"
        lines="$2"
        shift 2
        ;;
      -h|--help)
        print_help_audit
        return 0
        ;;
      *)
        die_with_help "$topic" "Unknown argument '$1'."
        ;;
    esac
  done

  local log_file="${AUDIT_LOG_FILE:-${DEFAULTS_DIR}/audit.jsonl}"
  if [ ! -f "$log_file" ]; then
    echo "No audit log yet."
    return 0
  fi

  tail -n "$lines" "$log_file" | python3 -c "
import sys, json
for line in sys.stdin:
    line = line.strip()
    if not line:
        continue
    try:
        e = json.loads(line)
        details = (' ' + e.get('details','')) if e.get('details') else ''
        print('{ts}  {action:<10}  {container}{details}'.format(
            ts=e.get('timestamp',''),
            action=e.get('action',''),
            container=e.get('container',''),
            details=details,
        ))
    except Exception:
        print(line)
"
}

cmd_cost() {
  local topic="cost"
  local name=""
  local latest=false

  while [ $# -gt 0 ]; do
    case "$1" in
      --latest)
        latest=true
        shift
        ;;
      -h|--help)
        print_help_cost
        return 0
        ;;
      *)
        [ -z "$name" ] || die_with_help "$topic" "Unexpected argument '$1'."
        name="$1"
        shift
        ;;
    esac
  done

  $latest && [ -n "$name" ] && die "Use a name or --latest, not both."

  require_vm
  name=$(resolve_target_container "$topic" "$name" "$latest")

  local state
  state=$(vm_exec docker inspect --format '{{.State.Status}}' "$name" 2>/dev/null || echo "unknown")
  if [ "$state" != "running" ]; then
    info "Starting container $name..."
    vm_exec docker start "$name" >/dev/null 2>&1
    sleep 1
  fi

  # Detect agent type to find the right config dir
  local agent_type config_dir
  agent_type=$(vm_exec docker inspect --format '{{index .Config.Labels "safe-agentic.agent-type"}}' "$name" 2>/dev/null || echo "")
  case "$agent_type" in
    codex) config_dir="/home/agent/.codex" ;;
    claude) config_dir="/home/agent/.claude" ;;
    *) config_dir="/home/agent/.claude" ;;  # default to claude
  esac

  info "Reading session data from $name ($agent_type)..."

  # Collect all JSONL lines from session files, then pipe to python3 for cost analysis
  local jsonl_data
  jsonl_data=$(vm_exec docker exec "$name" bash -c "
    find '${config_dir}/sessions' -name '*.jsonl' 2>/dev/null | while read -r f; do cat \"\$f\"; done
    [ -f '${config_dir}/history.jsonl' ] && cat '${config_dir}/history.jsonl' || true
  " 2>/dev/null || true)

  if [ -z "$jsonl_data" ]; then
    warn "No session data found in $name."
    return 0
  fi

  # Write python analyser to a temp file so we can pipe JSONL into it
  local py_script
  py_script=$(mktemp /tmp/agent-cost-XXXXXX.py)
  trap 'rm -f "$py_script"' RETURN

  cat >"$py_script" <<'PYEOF'
import sys, json, re

# Pricing per 1M tokens (input, output)
PRICES = {
    "claude-opus-4-6":    (15.0, 75.0),
    "claude-sonnet-4-6":  (3.0,  15.0),
    "claude-haiku-4-5":   (0.80,  4.0),
}
DEFAULT_PRICE = (3.0, 15.0)

totals_by_model = {}

for line in sys.stdin:
    line = line.strip()
    if not line:
        continue
    try:
        obj = json.loads(line)
    except json.JSONDecodeError:
        continue

    # Usage may be top-level or nested under payload
    usage = obj.get("usage") or (obj.get("payload") or {}).get("usage")
    if not usage or not isinstance(usage, dict):
        continue

    model = (
        obj.get("model")
        or (obj.get("payload") or {}).get("model")
        or "unknown"
    )
    # Normalise model name: strip date suffixes like -20250101
    model_key = re.sub(r"-\d{8}$", "", model)

    inp = int(usage.get("input_tokens", 0))
    out = int(usage.get("output_tokens", 0))

    if model_key not in totals_by_model:
        totals_by_model[model_key] = [0, 0]
    totals_by_model[model_key][0] += inp
    totals_by_model[model_key][1] += out

if not totals_by_model:
    print("No token usage found in session data.")
    sys.exit(0)

grand_in = grand_out = grand_cost = 0.0

print("")
print("  Model                      Input         Output    Est. Cost")
print("  " + "-" * 65)

for model_key in sorted(totals_by_model):
    inp, out = totals_by_model[model_key]
    price_in, price_out = PRICES.get(model_key, DEFAULT_PRICE)
    cost = (inp / 1_000_000) * price_in + (out / 1_000_000) * price_out
    grand_in   += inp
    grand_out  += out
    grand_cost += cost
    print(f"  {model_key:<26} {inp:>12,}  {out:>12,}    ${cost:>8.4f}")

print("  " + "-" * 65)
print(f"  {'TOTAL':<26} {int(grand_in):>12,}  {int(grand_out):>12,}    ${grand_cost:>8.4f}")
print("")
print(f"  Note: estimates use list pricing; cache tokens billed differently.")
print("")
PYEOF

  echo "$jsonl_data" | python3 "$py_script"
}

cmd_fleet() {
  local topic="fleet"
  local manifest=""
  local dry_run=false

  while [ $# -gt 0 ]; do
    case "$1" in
      --dry-run)
        dry_run=true
        shift
        ;;
      -h|--help)
        cmd_help "$topic"
        return 0
        ;;
      -*)
        die_with_help "$topic" "Unknown flag '$1'."
        ;;
      *)
        [ -z "$manifest" ] || die_with_help "$topic" "Unexpected argument '$1'."
        manifest="$1"
        shift
        ;;
    esac
  done

  [ -n "$manifest" ] || die_with_help "$topic" "Manifest file required."
  [ -f "$manifest" ] || die "Manifest file not found: $manifest"

  local agent_bin
  agent_bin="$(realpath "$0")"

  # Parse YAML manifest using python3 (no PyYAML dependency).
  # Outputs one spawn command per line, shell-quoted, prefixed with "CMD:".
  local parse_output
  parse_output=$(python3 - "$manifest" "$agent_bin" <<'PYEOF'
import sys
import shlex

manifest_path = sys.argv[1]
agent_bin     = sys.argv[2]

agents = []
current = None

with open(manifest_path) as f:
    for raw_line in f:
        line = raw_line.rstrip('\n')
        stripped = line.lstrip()

        # Start of a new agent entry
        if stripped.startswith('- name:'):
            current = {'name': stripped[len('- name:'):].strip()}
            agents.append(current)
            continue

        # Key-value field inside an agent entry
        if current is not None and ':' in stripped and not stripped.startswith('-') and not stripped.startswith('#'):
            key, _, val = stripped.partition(':')
            key = key.strip()
            val = val.strip()
            if key and val:
                # Normalise booleans
                if val.lower() == 'true':
                    val = True
                elif val.lower() == 'false':
                    val = False
                current[key] = val

for agent in agents:
    agent_type = agent.get('type', '')
    if not agent_type:
        sys.stderr.write(f"[fleet] skipping entry without type: {agent}\n")
        continue

    cmd = [agent_bin, 'spawn', agent_type]

    name = agent.get('name', '')
    if name:
        cmd += ['--name', name]

    repo = agent.get('repo', '')
    if repo:
        cmd += ['--repo', repo]

    if agent.get('ssh') is True:
        cmd.append('--ssh')

    if agent.get('reuse_auth') is True:
        cmd.append('--reuse-auth')

    if agent.get('reuse_gh_auth') is True:
        cmd.append('--reuse-gh-auth')

    if agent.get('docker') is True:
        cmd.append('--docker')

    if agent.get('auto_trust') is True:
        cmd.append('--auto-trust')

    if agent.get('background') is True:
        cmd.append('--background')

    prompt = agent.get('prompt', '')
    if prompt:
        cmd += ['--prompt', str(prompt)]

    aws = agent.get('aws', '')
    if aws:
        cmd += ['--aws', str(aws)]

    network = agent.get('network', '')
    if network:
        cmd += ['--network', str(network)]

    memory = agent.get('memory', '')
    if memory:
        cmd += ['--memory', str(memory)]

    cpus = agent.get('cpus', '')
    if cpus:
        cmd += ['--cpus', str(cpus)]

    print('CMD:' + shlex.join(cmd))
PYEOF
  ) || die "Failed to parse manifest: $manifest"

  local -a spawn_cmds=()
  while IFS= read -r line; do
    [[ "$line" == CMD:* ]] || continue
    spawn_cmds+=("${line#CMD:}")
  done <<< "$parse_output"

  [ ${#spawn_cmds[@]} -gt 0 ] || die "No valid agent entries found in manifest: $manifest"

  if $dry_run; then
    info "Dry run — would spawn ${#spawn_cmds[@]} agent(s):"
    local cmd_str
    for cmd_str in "${spawn_cmds[@]}"; do
      info "  $cmd_str"
    done
    return 0
  fi

  info "Spawning ${#spawn_cmds[@]} agent(s) from $manifest..."

  local -a pids=()
  local cmd_str
  for cmd_str in "${spawn_cmds[@]}"; do
    # Parse the shlex-quoted command back into an array safely (no eval)
    local -a cmd_array=()
    while IFS= read -r -d '' arg; do
      cmd_array+=("$arg")
    done < <(python3 -c "import shlex,sys; [sys.stdout.buffer.write(a.encode()+b'\x00') for a in shlex.split(sys.stdin.read())]" <<< "$cmd_str")
    "${cmd_array[@]}" &
    pids+=($!)
  done

  local all_ok=true
  local pid
  for pid in "${pids[@]}"; do
    if ! wait "$pid"; then
      all_ok=false
    fi
  done

  $all_ok || die "One or more agents failed to spawn."
  ok "All agents from fleet manifest spawned."
}

# ---------------------------------------------------------------------------
# Parse a pipeline YAML file with python3 (no PyYAML required).
# Outputs one line per step in the format:
#   name=<val> type=<val> repo=<val> prompt=<val> ssh=<val> reuse_auth=<val>
#   on_failure=<val> retry=<val> depends_on=<val>
# Values are base64-encoded to survive shell word splitting.
# ---------------------------------------------------------------------------
parse_pipeline_yaml() {
  local yaml_file="$1"

  python3 - "$yaml_file" <<'PYEOF'
import sys, base64, re

path = sys.argv[1]
with open(path) as f:
    lines = f.readlines()

pipeline_name = ""
steps = []
current_step = None
in_steps = False

for raw in lines:
    line = raw.rstrip('\n')
    stripped = line.lstrip()
    if not stripped or stripped.startswith('#'):
        continue

    indent = len(line) - len(stripped)

    # Top-level key: value
    if indent == 0:
        m = re.match(r'^(\w[\w-]*):\s*(.*)', stripped)
        if m:
            key, val = m.group(1), m.group(2).strip()
            if key == 'name' and not in_steps:
                pipeline_name = val
            elif key == 'steps':
                in_steps = True
                if current_step is not None:
                    steps.append(current_step)
                    current_step = None
        continue

    if not in_steps:
        continue

    # New step entry: "  - name: value"
    m = re.match(r'^-\s+(\w[\w_-]*):\s*(.*)', stripped)
    if m:
        if current_step is not None:
            steps.append(current_step)
        key, val = m.group(1), m.group(2).strip()
        current_step = {key: val}
        continue

    # Continuation field inside a step: "    key: value"
    m = re.match(r'^(\w[\w_-]*):\s*(.*)', stripped)
    if m and current_step is not None:
        key, val = m.group(1), m.group(2).strip()
        current_step[key] = val
        continue

if current_step is not None:
    steps.append(current_step)

def enc(v):
    return base64.b64encode(v.encode()).decode()

print("pipeline_name=" + enc(pipeline_name))
for step in steps:
    parts = []
    for field in ('name', 'type', 'repo', 'prompt', 'ssh', 'reuse_auth',
                  'on_failure', 'retry', 'depends_on'):
        val = step.get(field, '')
        parts.append(field + '=' + enc(val))
    print(' '.join(parts))
PYEOF
}

cmd_pipeline() {
  local topic="pipeline"
  local yaml_file=""
  local dry_run=false

  while [ $# -gt 0 ]; do
    case "$1" in
      --dry-run)
        dry_run=true
        shift
        ;;
      -h|--help)
        print_help_pipeline
        return 0
        ;;
      -*)
        die_with_help "$topic" "Unknown flag '$1'."
        ;;
      *)
        if [ -z "$yaml_file" ]; then
          yaml_file="$1"
        else
          die_with_help "$topic" "Unexpected argument '$1'."
        fi
        shift
        ;;
    esac
  done

  [ -n "$yaml_file" ] || die_with_help "$topic" "Pipeline YAML file required."
  [ -f "$yaml_file" ] || die "Pipeline file not found: $yaml_file"

  # Parse YAML
  local parsed_output
  parsed_output=$(parse_pipeline_yaml "$yaml_file") || die "Failed to parse pipeline YAML: $yaml_file"

  # Extract pipeline name (first line)
  local pipeline_name_b64 pipeline_name
  pipeline_name_b64=$(echo "$parsed_output" | head -n1 | sed 's/^pipeline_name=//')
  pipeline_name=$(echo "$pipeline_name_b64" | base64 -d 2>/dev/null || echo "")

  # Extract step lines (remaining lines)
  local step_lines
  step_lines=$(echo "$parsed_output" | tail -n +2)

  if [ -z "$step_lines" ]; then
    die "Pipeline '$yaml_file' contains no steps."
  fi

  # Count steps
  local step_count
  step_count=$(echo "$step_lines" | grep -c .)

  info "Pipeline: ${pipeline_name:-$(basename "$yaml_file")}"
  info "Steps: $step_count"

  if $dry_run; then
    info "Dry run — execution plan:"
    local i=0
    while IFS= read -r step_line; do
      [ -z "$step_line" ] && continue
      i=$((i + 1))

      local name type repo prompt ssh reuse_auth on_failure retry depends_on
      name=$(       echo "$step_line" | grep -o 'name=[^ ]*'        | cut -d= -f2- | base64 -d 2>/dev/null || echo "")
      type=$(       echo "$step_line" | grep -o 'type=[^ ]*'        | cut -d= -f2- | base64 -d 2>/dev/null || echo "claude")
      repo=$(       echo "$step_line" | grep -o 'repo=[^ ]*'        | cut -d= -f2- | base64 -d 2>/dev/null || echo "")
      prompt=$(     echo "$step_line" | grep -o 'prompt=[^ ]*'      | cut -d= -f2- | base64 -d 2>/dev/null || echo "")
      ssh=$(        echo "$step_line" | grep -o 'ssh=[^ ]*'         | cut -d= -f2- | base64 -d 2>/dev/null || echo "")
      reuse_auth=$( echo "$step_line" | grep -o 'reuse_auth=[^ ]*'  | cut -d= -f2- | base64 -d 2>/dev/null || echo "")
      on_failure=$(  echo "$step_line" | grep -o 'on_failure=[^ ]*' | cut -d= -f2- | base64 -d 2>/dev/null || echo "")
      retry=$(      echo "$step_line" | grep -o 'retry=[^ ]*'       | cut -d= -f2- | base64 -d 2>/dev/null || echo "0")
      depends_on=$( echo "$step_line" | grep -o 'depends_on=[^ ]*'  | cut -d= -f2- | base64 -d 2>/dev/null || echo "")

      [ -z "$type" ] && type="claude"
      [ -z "$retry" ] && retry="0"

      local flags=""
      [ -n "$repo" ]       && flags="$flags --repo $repo"
      [ -n "$prompt" ]     && flags="$flags --prompt '$prompt'"
      [[ "$ssh" == "true" ]] && flags="$flags --ssh"
      [[ "$reuse_auth" == "true" ]] && flags="$flags --reuse-auth"

      echo "  Step $i: $name"
      echo "    type:       $type"
      [ -n "$repo" ]        && echo "    repo:       $repo"
      [ -n "$prompt" ]      && echo "    prompt:     $prompt"
      [ -n "$depends_on" ]  && echo "    depends_on: $depends_on"
      [ -n "$on_failure" ]  && echo "    on_failure: $on_failure"
      [ "$retry" != "0" ]   && echo "    retry:      $retry"
      echo "    would run:  agent spawn $type$flags"
    done <<< "$step_lines"
    return 0
  fi

  # Execute pipeline
  local -a completed_steps=()
  local -a failed_steps=()
  # Track which on_failure steps were triggered so we don't double-run them
  local -a triggered_steps=()

  # Lookup a step line by name from step_lines (bash 3.2 compatible, no assoc arrays)
  lookup_step_by_name() {
    local target_name="$1"
    local target_b64
    target_b64=$(printf '%s' "$target_name" | base64 2>/dev/null)
    while IFS= read -r line; do
      [ -z "$line" ] && continue
      if [[ "$line" == *"name=$target_b64"* ]]; then
        echo "$line"
        return 0
      fi
    done <<< "$step_lines"
    return 1
  }

  pipeline_run_step() {
    local step_line="$1"
    [ -z "$step_line" ] && return 1

    local name type repo prompt ssh reuse_auth auto_trust background on_failure retry depends_on
    name=$(        echo "$step_line" | grep -o 'name=[^ ]*'        | cut -d= -f2- | base64 -d 2>/dev/null || echo "")
    type=$(        echo "$step_line" | grep -o 'type=[^ ]*'        | cut -d= -f2- | base64 -d 2>/dev/null || echo "")
    repo=$(        echo "$step_line" | grep -o 'repo=[^ ]*'        | cut -d= -f2- | base64 -d 2>/dev/null || echo "")
    prompt=$(      echo "$step_line" | grep -o 'prompt=[^ ]*'      | cut -d= -f2- | base64 -d 2>/dev/null || echo "")
    ssh=$(         echo "$step_line" | grep -o 'ssh=[^ ]*'         | cut -d= -f2- | base64 -d 2>/dev/null || echo "")
    reuse_auth=$(  echo "$step_line" | grep -o 'reuse_auth=[^ ]*'  | cut -d= -f2- | base64 -d 2>/dev/null || echo "")
    auto_trust=$(  echo "$step_line" | grep -o 'auto_trust=[^ ]*'  | cut -d= -f2- | base64 -d 2>/dev/null || echo "")
    background=$(  echo "$step_line" | grep -o 'background=[^ ]*'  | cut -d= -f2- | base64 -d 2>/dev/null || echo "")
    on_failure=$(  echo "$step_line" | grep -o 'on_failure=[^ ]*'  | cut -d= -f2- | base64 -d 2>/dev/null || echo "")
    retry=$(       echo "$step_line" | grep -o 'retry=[^ ]*'       | cut -d= -f2- | base64 -d 2>/dev/null || echo "0")
    depends_on=$(  echo "$step_line" | grep -o 'depends_on=[^ ]*'  | cut -d= -f2- | base64 -d 2>/dev/null || echo "")

    [ -z "$type" ]  && type="claude"
    [ -z "$retry" ] && retry="0"

    # Check depends_on
    if [ -n "$depends_on" ]; then
      local dep_satisfied=false
      local c
      for c in "${completed_steps[@]:-}"; do
        [ "$c" = "$depends_on" ] && dep_satisfied=true && break
      done
      if ! $dep_satisfied; then
        warn "Step '$name': skipping — dependency '$depends_on' not completed."
        return 1
      fi
    fi

    info "Step '$name': running (type=$type)"

    local -a spawn_args=("$type")
    [ -n "$repo" ]   && spawn_args+=(--repo "$repo")
    [ -n "$prompt" ] && spawn_args+=(--prompt "$prompt")
    [[ "$ssh" == "true" ]] && spawn_args+=(--ssh)
    [[ "$reuse_auth" == "true" ]] && spawn_args+=(--reuse-auth)
    [[ "$auto_trust" == "true" ]] && spawn_args+=(--auto-trust)
    [[ "$background" == "true" ]] && spawn_args+=(--background)
    spawn_args+=(--name "pipeline-${name}")

    local attempt=0
    local max_attempts=$(( retry + 1 ))
    local step_ok=false

    while [ "$attempt" -lt "$max_attempts" ]; do
      attempt=$(( attempt + 1 ))
      [ "$attempt" -gt 1 ] && info "Step '$name': retry $((attempt - 1))/$retry..."

      if cmd_spawn "${spawn_args[@]}"; then
        step_ok=true
        break
      else
        if [ "$attempt" -lt "$max_attempts" ]; then
          info "Step '$name': failed, waiting 5s before retry..."
          sleep 5
        fi
      fi
    done

    if $step_ok; then
      completed_steps+=("$name")
      ok "Step '$name': completed."
      return 0
    else
      failed_steps+=("$name")
      err "Step '$name': failed after $max_attempts attempt(s)."

      if [ -n "$on_failure" ]; then
        local already_triggered=false
        local t
        for t in "${triggered_steps[@]:-}"; do
          [ "$t" = "$on_failure" ] && already_triggered=true && break
        done
        local failure_line
        failure_line=$(lookup_step_by_name "$on_failure" || echo "")
        if ! $already_triggered && [ -n "$failure_line" ]; then
          triggered_steps+=("$on_failure")
          info "Step '$name': triggering on_failure step '$on_failure'..."
          pipeline_run_step "$failure_line" || true
        fi
      fi
      return 1
    fi
  }

  # Run steps in order
  local pipeline_ok=true
  while IFS= read -r step_line; do
    [ -z "$step_line" ] && continue

    local sname
    sname=$(echo "$step_line" | grep -o 'name=[^ ]*' | cut -d= -f2- | base64 -d 2>/dev/null || echo "")

    # Skip steps that were already triggered as on_failure handlers
    local was_triggered=false
    local t
    for t in "${triggered_steps[@]:-}"; do
      [ "$t" = "$sname" ] && was_triggered=true && break
    done
    $was_triggered && continue

    pipeline_run_step "$step_line" || pipeline_ok=false
  done <<< "$step_lines"

  local completed_count=${#completed_steps[@]}
  local failed_count=${#failed_steps[@]}

  echo ""
  info "Pipeline complete: $completed_count step(s) succeeded, $failed_count step(s) failed."
  $pipeline_ok && ok "Pipeline '${pipeline_name:-$(basename "$yaml_file")}' finished successfully."
  $pipeline_ok || die "Pipeline '${pipeline_name:-$(basename "$yaml_file")}' finished with failures."
}

print_help_orchestrate() {
  cat <<EOF
Usage: agent orchestrate <fleet.yaml> <pipeline.yaml> [--poll N]

Run a fleet of agents in parallel, wait for all to finish, then
automatically run a follow-up pipeline.

Options:
  --poll N    Poll interval in seconds (default: 30)

The orchestrator:
  1. Spawns all agents from the fleet manifest
  2. Polls 'agent list' every N seconds until all fleet agents exit
  3. Runs the pipeline manifest (consolidate, fix, create PR, etc.)

Examples:
  agent orchestrate examples/fleet-review-and-fix.yaml examples/pipeline-consolidate-and-fix.yaml
  agent orchestrate fleet.yaml pipeline.yaml --poll 15
EOF
}

cmd_orchestrate() {
  local topic="orchestrate"
  local fleet_file=""
  local pipeline_file=""
  local poll_interval=30

  while [ $# -gt 0 ]; do
    case "$1" in
      --poll)
        require_option_value "$topic" "--poll" "${2:-}"
        poll_interval="$2"
        shift 2
        ;;
      -h|--help)
        print_help_orchestrate
        return 0
        ;;
      *)
        if [ -z "$fleet_file" ]; then
          fleet_file="$1"
        elif [ -z "$pipeline_file" ]; then
          pipeline_file="$1"
        else
          die_with_help "$topic" "Unexpected argument '$1'."
        fi
        shift
        ;;
    esac
  done

  [ -n "$fleet_file" ] || die_with_help "$topic" "Fleet manifest required."
  [ -n "$pipeline_file" ] || die_with_help "$topic" "Pipeline manifest required."
  [ -f "$fleet_file" ] || die "Fleet manifest not found: $fleet_file"
  [ -f "$pipeline_file" ] || die "Pipeline manifest not found: $pipeline_file"

  # Phase 1: spawn fleet
  info "Phase 1: spawning fleet from $fleet_file..."
  cmd_fleet "$fleet_file" || die "Fleet spawn failed."

  # Collect fleet agent container names
  local -a fleet_containers=()
  local fleet_names
  fleet_names=$(python3 -c "
import sys
current = None
with open(sys.argv[1]) as f:
    for line in f:
        line = line.rstrip()
        if line.strip().startswith('- name:'):
            current = line.split(':', 1)[1].strip()
        elif current and line.strip().startswith('type:'):
            agent_type = line.split(':', 1)[1].strip()
            print('agent-' + agent_type + '-' + current)
            current = None
" "$fleet_file" 2>/dev/null)

  while IFS= read -r cname; do
    [ -n "$cname" ] && fleet_containers+=("$cname")
  done <<< "$fleet_names"

  local fleet_count=${#fleet_containers[@]}
  info "Waiting for $fleet_count fleet agent(s) to finish (polling every ${poll_interval}s)..."

  # Phase 2: wait for all fleet agents to exit
  while true; do
    local still_running=0
    local c
    for c in "${fleet_containers[@]}"; do
      local state
      state=$(vm_exec docker inspect --format '{{.State.Status}}' "$c" 2>/dev/null || echo "gone")
      if [ "$state" = "running" ]; then
        still_running=$((still_running + 1))
      fi
    done

    if [ "$still_running" -eq 0 ]; then
      ok "All $fleet_count fleet agents finished."
      break
    fi

    info "$still_running/$fleet_count agent(s) still running..."
    sleep "$poll_interval"
  done

  # Phase 3: run pipeline
  info "Phase 3: running pipeline from $pipeline_file..."
  cmd_pipeline "$pipeline_file"
}

cmd_pr() {
  local topic="pr"
  local name=""
  local latest=false
  local title=""
  local base="main"

  while [ $# -gt 0 ]; do
    case "$1" in
      --latest)
        latest=true
        shift
        ;;
      --title)
        require_option_value "$topic" "$1" "${2:-}"
        title="$2"
        shift 2
        ;;
      --base)
        require_option_value "$topic" "$1" "${2:-}"
        base="$2"
        shift 2
        ;;
      -h|--help)
        print_help_pr
        return 0
        ;;
      *)
        [ -z "$name" ] || die_with_help "$topic" "Unexpected argument '$1'."
        name="$1"
        shift
        ;;
    esac
  done

  $latest && [ -n "$name" ] && die_with_help "$topic" "Use a name or --latest, not both."

  if ! $latest && [ -z "$name" ]; then
    die_with_help "$topic" "Container name or --latest required."
  fi

  require_vm
  name=$(resolve_target_container "$topic" "$name" "$latest")

  local state
  state=$(vm_exec docker inspect --format '{{.State.Status}}' "$name" 2>/dev/null || echo "unknown")
  [ "$state" = "running" ] || die "Container $name is not running (state: $state)."

  # Require SSH label for push access
  local ssh_label
  ssh_label=$(vm_exec docker inspect --format '{{index .Config.Labels "safe-agentic.ssh"}}' "$name" 2>/dev/null || echo "")
  [ "$(echo "$ssh_label" | tr -d '[:space:]')" = "yes" ] || die "Container $name was not spawned with --ssh. Push requires SSH access."

  # Check for incomplete todos
  local todos_check
  # shellcheck disable=SC2016
  todos_check=$(vm_exec docker exec "$name" bash -c '
    f=/workspace/.safe-agentic/todos.json
    if [ -f "$f" ]; then
      python3 -c "
import json, sys
with open(\"$f\") as fh:
    todos = json.load(fh)
incomplete = [t for t in todos if not t.get(\"done\")]
if incomplete:
    print(\"incomplete\")
    sys.exit(1)
" 2>/dev/null
    fi
  ' 2>/dev/null || echo "incomplete")
  if [ "$(echo "$todos_check" | tr -d '[:space:]')" = "incomplete" ]; then
    die "Container $name has incomplete todos. Complete them with 'agent todo check' before creating a PR."
  fi

  # Get current branch
  local branch
  # shellcheck disable=SC2016
  branch=$(vm_exec docker exec "$name" bash -c 'cd "$(find /workspace -mindepth 1 -maxdepth 1 -type d | head -1)" 2>/dev/null || cd /workspace; git rev-parse --abbrev-ref HEAD' 2>/dev/null || echo "")
  branch=$(echo "$branch" | tr -d '[:space:]')
  [ -n "$branch" ] || die "Could not determine current branch in $name."
  if [ "$branch" = "main" ] || [ "$branch" = "master" ]; then
    die "Container $name is on branch '$branch'. Cannot create a PR from main/master."
  fi

  # Default title = branch name
  [ -n "$title" ] || title="$branch"

  info "Creating PR from $branch → $base in $name..."

  # shellcheck disable=SC2016
  # Stage and commit any uncommitted changes
  vm_exec docker exec -e SA_TITLE="$title" "$name" bash -c \
    'cd "$(find /workspace -mindepth 1 -maxdepth 1 -type d | head -1)" 2>/dev/null || cd /workspace; git add -A && git diff --cached --quiet || git commit -m "agent work: $SA_TITLE"'

  # shellcheck disable=SC2016
  # Push branch
  vm_exec docker exec -e SA_BRANCH="$branch" "$name" bash -c \
    'cd "$(find /workspace -mindepth 1 -maxdepth 1 -type d | head -1)" 2>/dev/null || cd /workspace; git push -u origin "$SA_BRANCH"' || die "Failed to push branch '$branch' in $name."

  # Create PR
  local pr_url
  # shellcheck disable=SC2016
  pr_url=$(vm_exec docker exec -e SA_TITLE="$title" -e SA_BASE="$base" -e SA_NAME="$name" "$name" bash -c \
    'cd "$(find /workspace -mindepth 1 -maxdepth 1 -type d | head -1)" 2>/dev/null || cd /workspace; gh pr create --title "$SA_TITLE" --body "Created by safe-agentic agent: $SA_NAME" --base "$SA_BASE"' 2>/dev/null || echo "")
  [ -n "$pr_url" ] || die "Failed to create PR from $name. Ensure gh is authenticated and the repo has a remote."

  ok "PR created: $pr_url"
}

cmd_aws_refresh() {
  local topic="aws-refresh"
  local name=""
  local latest=false
  local profile=""

  while [ $# -gt 0 ]; do
    case "$1" in
      --latest)
        latest=true
        shift
        ;;
      -h|--help)
        cat <<EOF
Usage: agent aws-refresh <name>|--latest [profile]

Refresh AWS credentials in a running container by re-reading
~/.aws/credentials from the host and writing into the container.

If profile is omitted, uses the profile from the container's AWS_PROFILE env var.

Examples:
  agent aws-refresh my-task
  agent aws-refresh my-task my-profile
  agent aws-refresh --latest other-profile
EOF
        return 0
        ;;
      *)
        if [ -z "$name" ]; then
          name="$1"
        elif [ -z "$profile" ]; then
          profile="$1"
        else
          die_with_help "$topic" "Unexpected argument '$1'."
        fi
        shift
        ;;
    esac
  done

  $latest && [ -n "$name" ] && die "Use a name or --latest, not both."

  require_vm
  name=$(resolve_target_container "$topic" "$name" "$latest")

  local state
  state=$(vm_exec docker inspect --format '{{.State.Status}}' "$name" 2>/dev/null || echo "unknown")
  [ "$state" = "running" ] || die "Container $name is not running (state: $state)."

  # Determine profile: explicit arg > container label > container env var
  if [ -z "$profile" ]; then
    profile=$(vm_exec docker inspect --format '{{index .Config.Labels "safe-agentic.aws"}}' "$name" 2>/dev/null || echo "")
  fi
  [ -n "$profile" ] || die "No AWS profile specified and none found on container $name. Pass a profile name."

  local aws_creds_file="${AWS_SHARED_CREDENTIALS_FILE:-$HOME/.aws/credentials}"
  [ -f "$aws_creds_file" ] || die "AWS credentials file not found: $aws_creds_file"
  if ! grep -q "^\[$profile\]" "$aws_creds_file"; then
    die "AWS profile '$profile' not found in $aws_creds_file"
  fi

  local creds_b64
  creds_b64=$(base64 < "$aws_creds_file")

  echo "$creds_b64" | vm_exec docker exec -i "$name" bash -c 'base64 -d > /home/agent/.aws/credentials && chmod 600 /home/agent/.aws/credentials'

  ok "AWS credentials refreshed in $name (profile: $profile)"
}

cmd="${1:-help}"
shift 2>/dev/null || true

case "$cmd" in
  setup)      cmd_setup "$@" ;;
  spawn)      cmd_spawn "$@" ;;
  shell)      cmd_shell "$@" ;;
  list)       cmd_list "$@" ;;
  attach)     cmd_attach "$@" ;;
  cp)         cmd_cp "$@" ;;
  stop)       cmd_stop "$@" ;;
  cleanup)    cmd_cleanup "$@" ;;
  update)     cmd_update "$@" ;;
  diagnose)   cmd_diagnose "$@" ;;
  vm)         cmd_vm "$@" ;;
  mcp-login)  cmd_mcp_login "$@" ;;
  sessions)   cmd_sessions "$@" ;;
  peek)       cmd_peek "$@" ;;
  diff)       cmd_diff "$@" ;;
  checkpoint) cmd_checkpoint "$@" ;;
  todo)        cmd_todo "$@" ;;
  review)     cmd_review "$@" ;;
  audit)       cmd_audit "$@" ;;
  cost)       cmd_cost "$@" ;;
  fleet)      cmd_fleet "$@" ;;
  pipeline)   cmd_pipeline "$@" ;;
  orchestrate) cmd_orchestrate "$@" ;;
  pr)         cmd_pr "$@" ;;
  aws-refresh) cmd_aws_refresh "$@" ;;
  config)      cmd_config "$@" ;;
  summary)     cmd_summary "$@" ;;
  tui)
    tui_bin="$REPO_DIR/tui/agent-tui"
    [ -x "$tui_bin" ] || die "TUI not built. Run 'make -C $REPO_DIR/tui build' first."
    exec "$tui_bin" "$@"
    ;;
  help|-h|--help) cmd_help "$@" ;;
  *)          die "Unknown command: $cmd. Run 'agent help' for usage." ;;
esac
