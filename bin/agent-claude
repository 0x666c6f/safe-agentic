#!/usr/bin/env bash
# Quick alias: spawn a Claude Code agent with a repo.
# Usage: agent-claude <repo-url> [repo-url...]
set -euo pipefail

AGENT="$(dirname "$0")/agent"

if [ $# -eq 0 ]; then
  echo "Usage: agent-claude <repo-url> [repo-url...]" >&2
  exit 1
fi

args=()
enable_ssh=false
for url in "$@"; do
  case "$url" in
    git@*|ssh://*) enable_ssh=true ;;
  esac
  args+=(--repo "$url")
done

if $enable_ssh; then
  args=(--ssh "${args[@]}")
fi

exec "$AGENT" spawn claude "${args[@]}"
