#!/usr/bin/env bash
# Quick alias: spawn a Codex agent with SSH and a repo.
# Usage: agent-codex <repo-url> [repo-url...]
set -euo pipefail

AGENT="$(dirname "$0")/agent"

if [ $# -eq 0 ]; then
  echo "Usage: agent-codex <repo-url> [repo-url...]" >&2
  exit 1
fi

args=(--ssh)
for url in "$@"; do
  args+=(--repo "$url")
done

exec "$AGENT" spawn codex "${args[@]}"
