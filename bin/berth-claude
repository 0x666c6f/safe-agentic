#!/usr/bin/env bash
set -euo pipefail

script_dir=$(CDPATH= cd -- "$(dirname -- "$0")" && pwd)
berth="$script_dir/berth"

if [ ! -x "$berth" ]; then
  berth="$(command -v berth || true)"
fi

if [ -z "$berth" ]; then
  echo "berth not found; build it with 'make build-all' or install berth first." >&2
  exit 1
fi

if [ "$#" -eq 0 ]; then
  echo "Usage: berth-claude <repo-url> [repo-url...] [flags]" >&2
  exit 2
fi

ssh_flag=0
args=(spawn claude)
raw_mode=0
for repo in "$@"; do
  if [ "$raw_mode" -eq 1 ]; then
    args+=("$repo")
    continue
  fi
  case "$repo" in
    -*)
      raw_mode=1
      args+=("$repo")
      ;;
    git@*|ssh://*)
      ssh_flag=1
      args+=(--repo "$repo")
      ;;
    *)
      args+=(--repo "$repo")
      ;;
  esac
done

if [ "$ssh_flag" -eq 1 ]; then
  args=(spawn claude --ssh "${args[@]:2}")
fi

exec "$berth" "${args[@]}"
